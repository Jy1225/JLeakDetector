11.             else {
12.                 Symbol body = makeListBody(parser);
13.                 if (parser.atEnd()) return Symbol.nothing;
14.                 list.add(body);
15.             }
16.             nextSymbol = parser.peek();
17.         }
18.         return new Maybe<Symbol>(list);
19.     }

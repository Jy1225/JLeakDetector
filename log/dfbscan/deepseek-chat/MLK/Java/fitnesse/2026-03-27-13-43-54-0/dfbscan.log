6.             if (indent(nextSymbol) > indent(list)) {
7.                 Maybe<Symbol> subList = populateList(parser, nextSymbol);
8.                 if (subList.isNothing()) return Symbol.nothing;
9.                 list.lastChild().add(subList.getValue());
10.             }
11.             else {
12.                 Symbol body = makeListBody(parser);
13.                 if (parser.atEnd()) return Symbol.nothing;
14.                 list.add(body);
15.             }
16.             nextSymbol = parser.peek();
17.         }
18.         return new Maybe<Symbol>(list);
19.     }
```


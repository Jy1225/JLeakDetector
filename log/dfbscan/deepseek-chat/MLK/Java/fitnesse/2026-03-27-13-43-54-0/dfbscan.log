1. public Maybe<Symbol> parse(Symbol current, Parser parser) {
2.         Symbol next = parser.moveNext(1);
3.         if (!next.isType(SymbolType.Whitespace)) return Symbol.nothing;
4. 
5.         String level = current.getContent().substring(1,2);
6.         if (ScanString.isDigits(level)) current.putProperty(Level, level);
7. 
8.         current.add(parser.parseToEnd(SymbolType.Newline));
9.         if (parser.peek().isType(SymbolType.Newline) && !parser.endsOn(SymbolType.Newline)) parser.moveNext(1);
10.         return new Maybe<Symbol>(current);
11.     }
```

1. public Maybe<Symbol> parse(Symbol current, Parser parser) {
2.         Maybe<String> name = parser.parseToAsString(SymbolType.CloseBrace);
3.         if (name.isNothing() || name.getValue().isEmpty()) return Symbol.nothing;
4.         String variableName = name.getValue();
5.         if (!ScanString.isVariableName(variableName)) return Symbol.nothing;
6. 
7.         current.add(variableName);
8. 
9.         Maybe<String> variableValue = parser.getVariableSource().findVariable(variableName);
10.         if (variableValue.isNothing()) {
11.             current.add(new Symbol(SymbolType.Meta).add("undefined variable: " + variableName));
12.         }
13.         else {
14.             Symbol variableValueSymbol = parser.parseWithParent(variableValue.getValue(), null);
15.             current.add(variableValueSymbol);
16.         }
17.         
18.         return new Maybe<Symbol>(current);
19.     }
```

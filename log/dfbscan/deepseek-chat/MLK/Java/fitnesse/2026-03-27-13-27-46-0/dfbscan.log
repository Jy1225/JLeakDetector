10.       String contentDisposition = headers.get("content-disposition");
11.       Matcher matcher = multipartHeaderPattern.matcher(contentDisposition);
12.       while (matcher.find())
13.         headers.put(matcher.group(1), matcher.group(2));
14. 
15.       String name = headers.get("name");
16.       if (headers.containsKey("filename")) {
17.         UploadedFile uploadedFile = createUploadedFile(headers, input, boundary);
18.         uploadedFiles.put(name, uploadedFile);
19.       } else {
20.         String value = input.readUpTo("\r\n" + boundary);
21.         inputs.put(name, value);
22.       }
23.     }
24.   }

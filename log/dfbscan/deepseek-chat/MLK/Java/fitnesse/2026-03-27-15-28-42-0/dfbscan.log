1. private Document getXmlDocument(String documentType) throws IOException, SAXException {
2.     String remotePathName = PathParser.render(remotePath);
3.     RequestBuilder builder = new RequestBuilder("/" + remotePathName);
4.     builder.addInput("responder", "proxy");
5.     builder.addInput("type", documentType);
6.     builder.setHostAndPort(remoteHostname, remotePort);
7.     if (remoteUsername != null)
8.       builder.addCredentials(remoteUsername, remotePassword);
9. 
10.     ResponseParser parser = ResponseParser.performHttpRequest(remoteHostname, remotePort, builder);
11. 
12.     if (parser.getStatus() == 404)
13.       throw new IOException("The remote resource, " + remoteUrl() + ", was not found.");
14.     if (parser.getStatus() == 401)
15.       throw new AuthenticationRequiredException(remoteUrl());
16. 
17.     String body = parser.getBody();
18.     return XmlUtil.newDocument(body);
19.   }

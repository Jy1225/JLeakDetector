1. protected void importRemotePageContent(WikiPage localPage) {
2.     try {
3.       Document doc = getXmlDocument("data");
4.       PageData remoteData = new PageXmlizer().deXmlizeData(doc);
5. 
6.       WikiPageProperties remoteProps = remoteData.getProperties();
7.       remoteProps.remove(PageData.PropertyEDIT);
8. 
9.       WikiImportProperty importProperty = new WikiImportProperty(remoteUrl());
10.       Date lastModificationTime = remoteProps.getLastModificationTime();
11.       importProperty.setLastRemoteModificationTime(lastModificationTime);
12.       importProperty.setAutoUpdate(autoUpdateSetting);
13.       importProperty.addTo(remoteProps);
14. 
15.       localPage.commit(remoteData);
16. 
17.       importerClient.pageImported(localPage);
18.     }
19.     catch (AuthenticationRequiredException e) {
20.       throw e;
21.     }
22.     catch (Exception e) {
23.       caughtException = e;
24.       importerClient.pageImportError(localPage, e);
25.     }
26.     importCount++;
27.   }
```

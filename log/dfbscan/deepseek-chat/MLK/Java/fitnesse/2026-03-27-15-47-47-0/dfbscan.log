11.         creationTime = makeVersionTimeFormat().parse(match.group(2));
12.       } catch (ParseException e) {
13.         throw new RuntimeException(e);
14.       }
15.     }
16.     return new ZipFileVersionInfo(complexName, author, creationTime, file);
17.   }

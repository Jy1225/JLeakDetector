1. public Symbol parse(Parser parser, Scanner scanner) {
2.         Symbol result = new Symbol(SymbolType.SymbolList);
3.         while (true) {
4.             Scanner backup = new Scanner(scanner);
5.             scanner.moveNextIgnoreFirst(this);
6.             if (scanner.isEnd()) break;
7.             Symbol currentToken = scanner.getCurrent();
8.             if (endsOn(currentToken.getType()) || parser.parentOwns(currentToken.getType(), this)) {
9.                 scanner.copy(backup);
10.                 break;
11.             }
12.             if (terminatesOn(currentToken.getType())) break;
13.             Rule currentRule = currentToken.getType().getWikiRule();
14.             Maybe<Symbol> parsedSymbol = currentRule.parse(currentToken, parser);
15.             if (parsedSymbol.isNothing()) {
16.                 ignoreFirst(currentToken.getType());
17.                 scanner.copy(backup);
18.             }
19.             else {
20.                 result.add(parsedSymbol.getValue());
21.                 clearIgnoresFirst();
22.             }
23.         }
24.         return result;
25.     }

2.   public FileVersion[] getRevisionData(final String label, final File... files) {
3.     if (label == null) {
4.       return persistence.getRevisionData(null, files);
5.     }
6.     final File file = new File(files[0].getParentFile(), label + ".zip");
7.     if (!file.exists()) {
8.       throw new NoSuchVersionException("There is no version '" + label + "'");
9.     }
10. 
11.     ZipFile zipFile = null;
12.     FileVersion[] versions = new FileVersion[files.length];
13.     int counter = 0;
14.     try {
15.       zipFile = new ZipFile(file);
16.       for (File f : files) {
17.         ZipFileVersion version = loadZipEntry(zipFile, f);
18.         if (version != null)
19.           versions[counter++] = version;
20.       }
21.       return versions;
22.     } catch (Exception e) {
23.       throw new RuntimeException(e);
24.     } finally {
25.       try {
26.         if (zipFile != null) {
27.           zipFile.close();

8.         int rowCount = 0;
9.         boolean isImportFixture = false;
10.         boolean colorTable = false;
11.         boolean isFirstColumnTitle = false;
12.         boolean isSecondRowTitle = false;
13.         boolean isCommentFixture = false;
14. 

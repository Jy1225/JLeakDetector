36.       for (int i = 0; i < players.length; i++) {
37.         players[i] = clone.getPlayerList().getPlayerID(players[i].getName());
38.       }
39.       text.append(defaultFileName + ",");
40.       text.append("\n");
41.       text.append("TripleA Engine Version: ,");
42.       text.append(ClientContext.engineVersion() + ",");
43.       text.append("\n");
44.       text.append("Game Name: ,");
45.       text.append(gameData.getGameName() + ",");
46.       text.append("\n");
47.       text.append("Game Version: ,");
48.       text.append(gameData.getGameVersion() + ",");
49.       text.append("\n");
50.       text.append("\n");
51.       text.append("Current Round: ,");
52.       text.append(currentRound + ",");
53.       text.append("\n");
54.       text.append("Number of Players: ,");
55.       text.append(statPanel.getPlayers().size() + ",");
56.       text.append("\n");
57.       text.append("Number of Alliances: ,");
58.       text.append(statPanel.getAlliances().size() + ",");
59.       text.append("\n");
60.       text.append("\n");
61.       text.append("Turn Order: ,");
62.       text.append("\n");
63.       final List<PlayerID> playerOrderList = new ArrayList<>();
64.       playerOrderList.addAll(gameData.getPlayerList().getPlayers());
65.       Collections.sort(playerOrderList, new PlayerOrderComparator(gameData));
66.       final Set<PlayerID> playerOrderSetNoDuplicates = new LinkedHashSet<>(playerOrderList);
67.       final Iterator<PlayerID> playerOrderIterator = playerOrderSetNoDuplicates.iterator();
68.       while (playerOrderIterator.hasNext()) {
69.         final PlayerID currentPlayerId = playerOrderIterator.next();
70.         text.append(currentPlayerId.getName()).append(",");
71.         final Iterator<String> allianceName =
72.             gameData.getAllianceTracker().getAlliancesPlayerIsIn(currentPlayerId).iterator();
73.         while (allianceName.hasNext()) {
74.           text.append(allianceName.next()).append(",");
75.         }
76.         text.append("\n");
77.       }
78.       text.append("\n");
79.       text.append("Winners: ,");
80.       final EndRoundDelegate delegateEndRound = (EndRoundDelegate) gameData.getDelegateList().getDelegate("endRound");
81.       if (delegateEndRound != null && delegateEndRound.getWinners() != null) {
82.         for (final PlayerID p : delegateEndRound.getWinners()) {
83.           text.append(p.getName()).append(",");
84.         }
85.       } else {
86.         text.append("none yet; game not over,");
87.       }
88.       text.append("\n");
89.       text.append("\n");
90.       text.append("Resource Chart: ,");
91.       text.append("\n");
92.       final Iterator<Resource> resourceIterator = gameData.getResourceList().getResources().iterator();
93.       while (resourceIterator.hasNext()) {
94.         text.append(resourceIterator.next().getName() + ",");
95.         text.append("\n");
96.       }
97.       // if short, we won't both showing production and unit info
98.       if (showPhaseStats) {
99.         text.append("\n");
100.         text.append("Production Rules: ,");
101.         text.append("\n");
102.         text.append("Name,Result,Quantity,Cost,Resource,\n");
103.         final Iterator<ProductionRule> purchaseOptionsIterator =
104.             gameData.getProductionRuleList().getProductionRules().iterator();
105.         while (purchaseOptionsIterator.hasNext()) {
106.           final ProductionRule pr = purchaseOptionsIterator.next();
107.           String costString = pr.toStringCosts().replaceAll("; ", ",");
108.           costString = costString.replaceAll(" ", ",");
109.           text.append(pr.getName()).append(",").append(pr.getResults().keySet().iterator().next().getName()).append(",")
110.               .append(pr.getResults().getInt(pr.getResults().keySet().iterator().next())).append(",").append(costString)
111.               .append(",");
112.           text.append("\n");
113.         }
114.         text.append("\n");
115.         text.append("Unit Types: ,");
116.         text.append("\n");
117.         text.append("Name,Listed Abilities\n");
118.         final Iterator<UnitType> allUnitsIterator = gameData.getUnitTypeList().iterator();
119.         while (allUnitsIterator.hasNext()) {
120.           final UnitAttachment ua = UnitAttachment.get(allUnitsIterator.next());
121.           if (ua == null) {
122.             continue;
123.           }
124.           String toModify = ua.allUnitStatsForExporter();
125.           toModify = toModify.replaceFirst("UnitType called ", "").replaceFirst(" with:", "")
126.               .replaceAll("games.strategy.engine.data.", "").replaceAll("\n", ";").replaceAll(",", ";");
127.           toModify = toModify.replaceAll("  ", ",");

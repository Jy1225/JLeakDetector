17.       }
18.     } finally {
19.       data.releaseReadLock();
20.     }
21.     try (final GZIPOutputStream zippedOut = new GZIPOutputStream(sink)) {
22.       // now write to file
23.       zippedOut.write(bytes.toByteArray());
24.     }
25.   }

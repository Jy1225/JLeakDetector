136.       text.append("\n");
137.       text.append("Turn Stats: ,");
138.       text.append("\n");
139.       text.append("Round,Player Turn,Phase Name,");
140.       for (final IStat stat : stats) {
141.         for (final PlayerID player : players) {
142.           text.append(stat.getName()).append(" ");
143.           text.append(player.getName());
144.           text.append(",");
145.         }
146.         for (final String alliance : alliances) {
147.           text.append(stat.getName()).append(" ");
148.           text.append(alliance);
149.           text.append(",");
150.         }
151.       }
152.       for (final IStat element : statsExtended) {
153.         for (final PlayerID player : players) {
154.           text.append(element.getName()).append(" ");
155.           text.append(player.getName());
156.           text.append(",");
157.         }
158.         for (final String alliance : alliances) {
159.           text.append(element.getName()).append(" ");
160.           text.append(alliance);
161.           text.append(",");
162.         }
163.       }
164.       text.append("\n");
165.       clone.getHistory().gotoNode(clone.getHistory().getLastNode());
166.       @SuppressWarnings("unchecked")
167.       final Enumeration<TreeNode> nodes = ((DefaultMutableTreeNode) clone.getHistory().getRoot()).preorderEnumeration();
168.       PlayerID currentPlayer = null;
169.       int round = 0;
170.       while (nodes.hasMoreElements()) {
171.         // we want to export on change of turn
172.         final HistoryNode element = (HistoryNode) nodes.nextElement();
173.         if (element instanceof Round) {
174.           round++;
175.         }
176.         if (!(element instanceof Step)) {
177.           continue;
178.         }
179.         final Step step = (Step) element;
180.         if (step.getPlayerID() == null || step.getPlayerID().isNull()) {
181.           continue;
182.         }
183.         // this is to stop from having multiple entries for each players turn.
184.         if (!showPhaseStats) {
185.           if (step.getPlayerID() == currentPlayer) {
186.             continue;
187.           }
188.         }
189.         currentPlayer = step.getPlayerID();
190.         clone.getHistory().gotoNode(element);
191.         final String playerName = step.getPlayerID() == null ? "" : step.getPlayerID().getName() + ": ";
192.         String stepName = step.getStepName();
193.         // copied directly from TripleAPlayer, will probably have to be updated in the future if more delegates are made
194.         if (stepName.endsWith("Bid")) {
195.           stepName = "Bid";
196.         } else if (stepName.endsWith("Tech")) {
197.           stepName = "Tech";
198.         } else if (stepName.endsWith("TechActivation")) {
199.           stepName = "TechActivation";
200.         } else if (stepName.endsWith("Purchase")) {
201.           stepName = "Purchase";
202.         } else if (stepName.endsWith("NonCombatMove")) {
203.           stepName = "NonCombatMove";
204.         } else if (stepName.endsWith("Move")) {
205.           stepName = "Move";
206.         } else if (stepName.endsWith("Battle")) {
207.           stepName = "Battle";
208.         } else if (stepName.endsWith("BidPlace")) {
209.           stepName = "BidPlace";
210.         } else if (stepName.endsWith("Place")) {
211.           stepName = "Place";
212.         } else if (stepName.endsWith("Politics")) {
213.           stepName = "Politics";
214.         } else if (stepName.endsWith("EndTurn")) {
215.           stepName = "EndTurn";
216.         } else {
217.           stepName = "";
218.         }
219.         text.append(round).append(",").append(playerName).append(",").append(stepName).append(",");
220.         for (final IStat stat : stats) {
221.           for (final PlayerID player : players) {
222.             text.append(stat.getFormatter().format(stat.getValue(player, clone)));
223.             text.append(",");
224.           }
225.           for (final String alliance : alliances) {
226.             text.append(stat.getFormatter().format(stat.getValue(alliance, clone)));
227.             text.append(",");
228.           }
229.         }
230.         for (final IStat element2 : statsExtended) {

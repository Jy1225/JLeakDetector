233.             text.append(",");
234.           }
235.           for (final String alliance : alliances) {
236.             text.append(element2.getFormatter().format(element2.getValue(alliance, clone)));
237.             text.append(",");
238.           }
239.         }
240.         text.append("\n");
241.       }
242.     } finally {
243.       gameData.releaseReadLock();
244.     }
245.     try (final FileWriter writer = new FileWriter(chooser.getSelectedFile())) {
246.       writer.write(text.toString());
247.     } catch (final IOException e1) {
248.       ClientLogger.logQuietly(e1);
249.     }
250.   }

9.     }
10.     logger.info("Backing up database to " + backupDir.getAbsolutePath());
11.     try (final Connection con = getDerbyConnection()) {
12.       // http://www-128.ibm.com/developerworks/db2/library/techarticle/dm-0502thalamati/
13.       final String sqlstmt = "CALL SYSCS_UTIL.SYSCS_BACKUP_DATABASE(?)";
14.       final CallableStatement cs = con.prepareCall(sqlstmt);
15.       cs.setString(1, backupDir.getAbsolutePath());
16.       cs.execute();
17.       cs.close();
18.     } catch (final Exception e) {
19.       logger.log(Level.SEVERE, "Could not back up database", e);
20.     }
21.     logger.info("Done backing up database");
22.   }

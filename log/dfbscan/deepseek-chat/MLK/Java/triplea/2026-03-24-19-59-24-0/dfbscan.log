3.       return;
4.     }
5.     // run in a new thread, so that we do not delay the game
6.     String folder = clipName;
7.     if (playerId != null) {
8.       folder += "_" + playerId.getName();
9.     }
10. 
11.     final URI clip = loadClip(folder).orElse(loadClip(clipName).orElse(null));

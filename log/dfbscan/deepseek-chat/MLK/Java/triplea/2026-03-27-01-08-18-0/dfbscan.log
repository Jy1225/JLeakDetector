1. protected List<URL> findClipFiles(final String resourceAndPathUrl) {
2.     final List<URL> availableSounds = new ArrayList<>();
3.     final URL thisSoundUrl = resourceLoader.getResource(resourceAndPathUrl);
4.     if (thisSoundUrl == null) {
5.       return availableSounds;
6.     }
7.     URI thisSoundUri;
8.     File thisSoundFile;
9.     // we are checking to see if this is a file, to see if it is a directory, or a sound, or a zipped directory, or a
10.     // zipped sound. There
11.     // might be a better way to do this...
12.     try {
13.       thisSoundUri = thisSoundUrl.toURI();
14.       try {
15.         thisSoundFile = new File(thisSoundUri);
16.       } catch (final Exception e) {
17.         try {
18.           thisSoundFile = new File(thisSoundUri.getPath());
19.         } catch (final Exception e3) {
20.           thisSoundFile = new File(thisSoundUrl.getPath());
21.         }
22.       }
23.     } catch (final URISyntaxException e1) {
24.       try {
25.         thisSoundFile = new File(thisSoundUrl.getPath());
26.       } catch (final Exception e4) {
27.         thisSoundFile = null;
28.       }
29.     } catch (final Exception e2) {
30.       thisSoundFile = null;
31.     }
32. 
33.     if (thisSoundFile == null || !thisSoundFile.exists()) {
34.       // final long startTime = System.currentTimeMillis();
35.       // we are probably using zipped sounds. there might be a better way to do this...
36.       final String soundFilePath = thisSoundUrl.getPath();
37.       if (soundFilePath != null && soundFilePath.length() > 5 && soundFilePath.contains(".zip!")) {
38.         // so the URL with a zip or jar in it, will start with "file:", and unfortunately when you make a file and test
39.         // if it exists, if it
40.         // starts with that it doesn't exist
41.         final int index1 = Math.max(0, Math.min(soundFilePath.length(),
42.             soundFilePath.contains("file:") ? soundFilePath.indexOf("file:") + 5 : 0));
43.         final String zipFilePath = soundFilePath.substring(index1,
44.             Math.max(index1, Math.min(soundFilePath.length(), soundFilePath.lastIndexOf("!"))));
45.         if (zipFilePath.length() > 5 && zipFilePath.endsWith(".zip")) {
46.           String decoded;
47.           try {
48.             // the file path may have spaces, which in a URL are equal to %20, but if we make a file using that it will
49.             // fail, so we need to decode
50.             decoded = URLDecoder.decode(zipFilePath, "UTF-8");
51.           } catch (final UnsupportedEncodingException uee) {
52.             decoded = zipFilePath.replaceAll("%20", " ");
53.           }
54. 
55.           try {
56.             final File zipFile = new File(decoded);
57.             if (zipFile.exists()) {
58.               try (ZipFile zf = new ZipFile(zipFile)) {
59. 
60.                 final Enumeration<? extends ZipEntry> zipEnumeration = zf.entries();
61.                 while (zipEnumeration.hasMoreElements()) {
62.                   final ZipEntry zipElement = zipEnumeration.nextElement();
63.                   if (isZippedMp3(zipElement, resourceAndPathUrl)) {
64.                     try {
65.                       final URL zipSoundUrl = resourceLoader.getResource(zipElement.getName());
66.                       if (zipSoundUrl == null) {
67.                         continue;
68.                       }
69.                       availableSounds.add(zipSoundUrl);
70.                     } catch (final Exception e) {
71.                       ClientLogger.logQuietly(e);
72.                     }
73.                   }
74.                 }
75. 
76.               }
77.             }
78.           } catch (final Exception e) {
79.             ClientLogger.logQuietly(e);
80.           }
81.         }
82.       }
83.     } else {
84.       // we must be using unzipped sounds
85.       if (!thisSoundFile.isDirectory()) {
86.         if (!(isSoundFileNamed(thisSoundFile))) {
87.           return availableSounds;
88.         }
89.         availableSounds.add(thisSoundUrl);
90.       }
91.     }
92.     if (thisSoundFile.isDirectory()) {
93.       for (final File soundFile : thisSoundFile.listFiles()) {
94.         if (isSoundFileNamed(soundFile)) {
95.           try {
96.             final URL individualSoundUrl = soundFile.toURI().toURL();
97.             availableSounds.add(individualSoundUrl);
98.           } catch (final MalformedURLException e) {
99.             String msg = "Error " + e.getMessage() + " with sound file: " + soundFile.getPath();
100.             ClientLogger.logQuietly(msg, e);
101.           }
102.         }
103.       }
104.     } else {
105.       if (!isSoundFileNamed(thisSoundFile)) {
106.         return availableSounds;
107.       }
108.       availableSounds.add(thisSoundUrl);
109.     }
110.     return availableSounds;
111.   }

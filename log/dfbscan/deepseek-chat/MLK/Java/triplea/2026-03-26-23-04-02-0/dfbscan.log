1. private static String executeCommandAndGetResults(final String command) {
2.     Process p = null;
3.     try {
4.       p = new ProcessBuilder(command).start();
5.     } catch (final Exception e) {
6.       try {
7.         p = Runtime.getRuntime().exec(command);
8.       } catch (final IOException e2) {
9.         ClientLogger.logQuietly("Ignoring error while executing command: " + command, e);
10.       }
11.     }
12.     if (p == null) {
13.       return null;
14.     }
15.     try {
16.       final StringBuilder builder = new StringBuilder();
17.       final BufferedReader in = new BufferedReader(new InputStreamReader(p.getInputStream()));
18.       while (true) {
19.         try {
20.           final String line = in.readLine();
21.           if (line == null) {
22.             break;
23.           }
24.           builder.append(line).append("\r\n");
25.         } catch (final IOException e) {
26.           break;
27.         }
28.       }
29.       in.close();
30.       return builder.toString();
31.     } catch (final IOException e) {
32.       ClientLogger.logQuietly("IOException while executing command: " + command, e);
33.       return null;
34.     }
35.   }

1. protected void saveToFile(final PrintGenerationData printData) throws IOException {
2.     final GameData gameData = printData.getData();
3.     final Iterator<GameStep> gameStepIterator = gameData.getSequence().iterator();
4.     while (gameStepIterator.hasNext()) {
5.       final GameStep currentStep = gameStepIterator.next();
6.       if (currentStep.getDelegate() != null && currentStep.getDelegate().getClass() != null) {
7.         final String delegateClassName = currentStep.getDelegate().getClass().getName();
8.         if (delegateClassName.equals(InitializationDelegate.class.getName())
9.             || delegateClassName.equals(BidPurchaseDelegate.class.getName())
10.             || delegateClassName.equals(BidPlaceDelegate.class.getName())
11.             || delegateClassName.equals(EndRoundDelegate.class.getName())) {
12.           continue;
13.         }
14.       } else if (currentStep.getName() != null
15.           && (currentStep.getName().endsWith("Bid") || currentStep.getName().endsWith("BidPlace"))) {
16.         continue;
17.       }
18.       final PlayerID currentPlayerId = currentStep.getPlayerID();
19.       if (currentPlayerId != null && !currentPlayerId.isNull()) {
20.         playerSet.add(currentPlayerId);
21.       }
22.     }
23.     printData.getOutDir().mkdir();
24.     final File outFile = new File(printData.getOutDir(), "General Information.csv");
25.     try (final FileWriter turnWriter = new FileWriter(outFile, true)) {
26.       turnWriter.write("Turn Order\r\n");
27.       final Set<PlayerID> noDuplicates = removeDups(playerSet);
28.       final Iterator<PlayerID> playerIterator = noDuplicates.iterator();
29.       int count = 1;
30.       while (playerIterator.hasNext()) {
31.         final PlayerID currentPlayerId = playerIterator.next();
32.         turnWriter.write(count + ". " + currentPlayerId.getName() + "\r\n");
33.         count++;
34.       }
35.     }
36.   }

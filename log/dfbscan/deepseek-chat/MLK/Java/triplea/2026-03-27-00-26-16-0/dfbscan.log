10.           existing.add(rs.getString("TABLE_NAME").toUpperCase());
11.         }
12.         rs.close();
13.         if (!existing.contains("TA_USERS")) {
14.           final Statement s = conn.createStatement();
15.           s.execute("create table ta_users" + "(" + "userName varchar(40) NOT NULL PRIMARY KEY, "
16.               + "password varchar(40) NOT NULL, " + "email varchar(40) NOT NULL, " + "joined timestamp NOT NULL, "
17.               + "lastLogin timestamp NOT NULL, " + "admin integer NOT NULL " + ")");

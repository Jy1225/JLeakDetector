3.         BufferedReader bufferedReader = null;
4.         try {
5.             // connection
6.             URL realUrl = new URL(url);
7.             connection = (HttpURLConnection) realUrl.openConnection();
8. 
9.             // trust-https
10.             boolean useHttps = url.startsWith("https");
11.             if (useHttps) {
12.                 HttpsURLConnection https = (HttpsURLConnection) connection;
13.                 trustAllHosts(https);
14.             }
15. 
16.             // connection setting
17.             connection.setRequestMethod("POST");
18.             connection.setDoOutput(true);
19.             connection.setDoInput(true);
20.             connection.setUseCaches(false);
21.             connection.setReadTimeout(timeout * 1000);
22.             connection.setConnectTimeout(timeout * 1000);
23.             connection.setRequestProperty("connection", "Keep-Alive");
24.             connection.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
25.             connection.setRequestProperty("Accept-Charset", "application/json;charset=UTF-8");
26. 
27.             if(accessToken!=null && accessToken.trim().length()>0){

2.     public PrivateKey parseValue(String value) throws GuacamoleServerException {
3. 
4.         if (value == null || value.isEmpty())
5.             return null;
6. 
7.         try {
8. 
9.             // Open and read the file specified in the configuration.
10.             File keyFile = new File(value);
11.             FileInputStream keyStreamIn = new FileInputStream(keyFile);
12.             ByteArrayOutputStream keyStreamOut = new ByteArrayOutputStream();
13.             byte[] keyBuffer = new byte[1024];
14. 
15.             for (int readBytes; (readBytes = keyStreamIn.read(keyBuffer)) != -1;)
16.                 keyStreamOut.write(keyBuffer, 0, readBytes);
17. 
18.             keyStreamIn.close();
19.             final byte[] keyBytes = keyStreamOut.toByteArray();
20. 
21.             // Set up decryption infrastructure
22.             KeyFactory keyFactory = KeyFactory.getInstance("RSA");
23.             KeySpec keySpec = new PKCS8EncodedKeySpec(keyBytes);
24.             return keyFactory.generatePrivate(keySpec);
25. 
26.         }
27.         catch (FileNotFoundException e) {
28.             throw new GuacamoleServerException("Could not find the specified key file.", e);
29.         }
30.         catch (IOException e) {
31.             throw new GuacamoleServerException("Could not read in the specified key file.", e);
32.         }
33.         catch (NoSuchAlgorithmException e) {
34.             throw new GuacamoleServerException("RSA algorithm is not available.", e);
35.         }
36.         catch (InvalidKeySpecException e) {
37.             throw new GuacamoleServerException("Key is not in expected PKCS8 encoding.", e);
38.         }
39. 
40.     }

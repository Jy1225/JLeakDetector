1. public static ReturnT postBody(String url, String accessToken, int timeout, Object requestObj, Class returnTargClassOfT) {
2.         HttpURLConnection connection = null;
3.         BufferedReader bufferedReader = null;
4.         try {
5.             // connection
6.             URL realUrl = new URL(url);
7.             connection = (HttpURLConnection) realUrl.openConnection();
8. 
9.             // trust-https
10.             boolean useHttps = url.startsWith("https");
11.             if (useHttps) {
12.                 HttpsURLConnection https = (HttpsURLConnection) connection;
13.                 trustAllHosts(https);
14.             }
15. 
16.             // connection setting
17.             connection.setRequestMethod("POST");
18.             connection.setDoOutput(true);
19.             connection.setDoInput(true);
20.             connection.setUseCaches(false);
21.             connection.setReadTimeout(timeout * 1000);
22.             connection.setConnectTimeout(timeout * 1000);
23.             connection.setRequestProperty("connection", "Keep-Alive");
24.             connection.setRequestProperty("Content-Type", "application/json;charset=UTF-8");
25.             connection.setRequestProperty("Accept-Charset", "application/json;charset=UTF-8");
26. 
27.             if(accessToken!=null && accessToken.trim().length()>0){
28.                 connection.setRequestProperty(XXL_JOB_ACCESS_TOKEN, accessToken);
29.             }
30. 
31.             // do connection
32.             connection.connect();
33. 
34.             // write requestBody
35.             if (requestObj != null) {
36.                 String requestBody = GsonTool.toJson(requestObj);
37. 
38.                 DataOutputStream dataOutputStream = new DataOutputStream(connection.getOutputStream());
39.                 dataOutputStream.write(requestBody.getBytes("UTF-8"));
40.                 dataOutputStream.flush();
41.                 dataOutputStream.close();
42.             }
43. 
44.             /*byte[] requestBodyBytes = requestBody.getBytes("UTF-8");
45.             connection.setRequestProperty("Content-Length", String.valueOf(requestBodyBytes.length));
46.             OutputStream outwritestream = connection.getOutputStream();
47.             outwritestream.write(requestBodyBytes);
48.             outwritestream.flush();
49.             outwritestream.close();*/
50. 
51.             // valid StatusCode
52.             int statusCode = connection.getResponseCode();
53.             if (statusCode != 200) {
54.                 return new ReturnT<String>(ReturnT.FAIL_CODE, "xxl-job remoting fail, StatusCode("+ statusCode +") invalid. for url : " + url);
55.             }
56. 
57.             // result
58.             bufferedReader = new BufferedReader(new InputStreamReader(connection.getInputStream(), "UTF-8"));
59.             StringBuilder result = new StringBuilder();
60.             String line;
61.             while ((line = bufferedReader.readLine()) != null) {
62.                 result.append(line);
63.             }
64.             String resultJson = result.toString();
65. 
66.             // parse returnT
67.             try {
68.                 ReturnT returnT = GsonTool.fromJson(resultJson, ReturnT.class, returnTargClassOfT);
69.                 return returnT;
70.             } catch (Exception e) {
71.                 logger.error("xxl-job remoting (url="+url+") response content invalid("+ resultJson +").", e);
72.                 return new ReturnT<String>(ReturnT.FAIL_CODE, "xxl-job remoting (url="+url+") response content invalid("+ resultJson +").");
73.             }
74. 
75.         } catch (Exception e) {
76.             logger.error(e.getMessage(), e);
77.             return new ReturnT<String>(ReturnT.FAIL_CODE, "xxl-job remoting error("+ e.getMessage() +"), for url : " + url);
78.         } finally {
79.             try {
80.                 if (bufferedReader != null) {
81.                     bufferedReader.close();
82.                 }
83.                 if (connection != null) {
84.                     connection.disconnect();
85.                 }
86.             } catch (Exception e2) {
87.                 logger.error(e2.getMessage(), e2);
88.             }
89.         }
90.     }

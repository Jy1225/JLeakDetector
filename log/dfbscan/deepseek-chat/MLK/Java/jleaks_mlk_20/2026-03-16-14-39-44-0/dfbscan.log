35.             // do nothing, fall through and return 'target'
36.           } catch (IOException e) {
37.             // do nothing, fall through and return 'target'
38.           } catch (RuntimeException e) {
39.             // do nothing, fall through and return 'target'
40.           }
41.         }
42.       }
43.     }
44. 

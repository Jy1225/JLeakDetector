13.             }
14.         } catch (FileNotFoundException | EOFException e) {
15.             // FileNotFoundException: Ignore, may be new.
16.             // EOFException: Ignore, this means the file was missing or corrupt
17.         } catch (IOException | ClassNotFoundException e) {
18.             throw new ConnectException(e);
19.         }
20.     }

2.   public static <T> T translateIntoOtherGameData(final T object, final GameData translateInto) {
3.     try {
4.       ByteArrayOutputStream sink = new ByteArrayOutputStream(1024);
5.       final GameObjectOutputStream out = new GameObjectOutputStream(sink);
6.       out.writeObject(object);
7.       out.flush();
8.       out.close();
9.       final ByteArrayInputStream source = new ByteArrayInputStream(sink.toByteArray());
10.       sink = null;
11.       final GameObjectStreamFactory factory = new GameObjectStreamFactory(translateInto);
12.       final ObjectInputStream in = factory.create(source);
13.       try {
14.         return (T) in.readObject();
15.       } catch (final ClassNotFoundException ex) {
16.         // should never happen
17.         throw new RuntimeException(ex);
18.       }
19.     } catch (final IOException ioe) {
20.       throw new RuntimeException(ioe);
21.     }
22.   }

1. private static List<NewGameChooserEntry> populateFromZip(final File map) {
2.     boolean badMapZip = false;
3.     final List<NewGameChooserEntry> entries = new ArrayList<>();
4. 
5.     try (ZipFile zipFile = new ZipFile(map);
6.         final URLClassLoader loader = new URLClassLoader(new URL[] {map.toURI().toURL()})) {
7.       final Enumeration<? extends ZipEntry> zipEntryEnumeration = zipFile.entries();
8.       while (zipEntryEnumeration.hasMoreElements()) {
9.         final ZipEntry entry = zipEntryEnumeration.nextElement();
10.         if (entry.getName().contains("games/") &&  entry.getName().toLowerCase().endsWith(".xml")) {
11.           final ZipProcessingResult result = processZipEntry(loader, entry, entries);
12.           if (result == ZipProcessingResult.ERROR) {
13.             badMapZip = true;
14.             break;
15.           }
16.         }
17.       }
18.     } catch (final IOException e) {
19.       confirmWithUserAndThenDeleteCorruptZipFile(map, Optional.of(e.getMessage()));
20.     }
21. 
22.     if (badMapZip) {
23.       confirmWithUserAndThenDeleteCorruptZipFile(map, Optional.empty());
24.     }
25.     return entries;
26.   }

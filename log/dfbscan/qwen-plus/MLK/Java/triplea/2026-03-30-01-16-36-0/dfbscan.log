1. public void stopGame() {
2.     // we have already shut down
3.     if (m_isGameOver) {
4.       System.out.println("Game previously stopped, cannot stop again.");
5.       return;
6.     } else if (HeadlessGameServer.headless()) {
7.       System.out.println("Attempting to stop game.");
8.     }
9.     m_isGameOver = true;
10.     m_delegateExecutionStoppedLatch.countDown();
11.     // tell the players (especially the AI's) that the game is stopping, so stop doing stuff.
12.     for (final IGamePlayer player : m_gamePlayers.values()) {
13.       // not sure whether to put this before or after we delegate execution block, but definitely before the game loader
14.       // shutdown
15.       player.stopGame();
16.     }
17.     // block delegate execution to prevent outbound messages to the players while we shut down.
18.     try {
19.       if (!m_delegateExecutionManager.blockDelegateExecution(16000)) {
20.         System.err.println("Could not stop delegate execution.");
21.         if (HeadlessGameServer.getInstance() != null) {
22.           HeadlessGameServer.getInstance().printThreadDumpsAndStatus();
23.         } else {
24.           ErrorConsole.getConsole().dumpStacks();
25.         }
26.         // Try one more time
27.         if (!m_delegateExecutionManager.blockDelegateExecution(16000)) {
28.           System.err.println("Exiting...");
29.           System.exit(-1);
30.         }
31.       }
32.     } catch (final InterruptedException e) {
33.       ClientLogger.logQuietly(e);
34.     }
35.     // shutdown
36.     try {
37.       m_delegateExecutionManager.setGameOver();
38.       getGameModifiedBroadcaster().shutDown();
39.       m_randomStats.shutDown();
40.       m_channelMessenger.unregisterChannelSubscriber(m_gameModifiedChannel, IGame.GAME_MODIFICATION_CHANNEL);
41.       m_remoteMessenger.unregisterRemote(SERVER_REMOTE);
42.       m_vault.shutDown();
43.       final Iterator<IGamePlayer> localPlayersIter = m_gamePlayers.values().iterator();
44.       while (localPlayersIter.hasNext()) {
45.         final IGamePlayer gp = localPlayersIter.next();
46.         m_remoteMessenger.unregisterRemote(getRemoteName(gp.getPlayerID(), m_data));
47.       }
48.       final Iterator<IDelegate> delegateIter = m_data.getDelegateList().iterator();
49.       while (delegateIter.hasNext()) {
50.         final IDelegate delegate = delegateIter.next();
51.         final Class<? extends IRemote> remoteType = delegate.getRemoteType();
52.         // if its null then it shouldnt be added as an IRemote
53.         if (remoteType == null) {
54.           continue;
55.         }
56.         m_remoteMessenger.unregisterRemote(getRemoteName(delegate));
57.       }
58.     } catch (final RuntimeException e) {
59.       ClientLogger.logQuietly(e);
60.     } finally {
61.       m_delegateExecutionManager.resumeDelegateExecution();
62.     }
63.     m_data.getGameLoader().shutDown();
64.     if (HeadlessGameServer.headless()) {
65.       System.out.println("StopGame successful.");
66.     }
67.   }

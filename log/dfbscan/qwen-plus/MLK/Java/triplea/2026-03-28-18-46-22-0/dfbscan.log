1. private void removeMutedMac(final String mac) {
2.     logger.fine("Removing muted mac:" + mac);
3.     final Connection con = Database.getDerbyConnection();
4.     try {
5.       final PreparedStatement ps = con.prepareStatement("delete from muted_macs where mac = ?");

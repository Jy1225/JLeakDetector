14.       }
15.       final ObjectOutputStream out = new ObjectOutputStream(new FileOutputStream(cache));
16.       out.writeObject(serializableMap);
17.       out.close();
18.     } catch (final IOException e) {
19.       ClientLogger.logQuietly(e);
20.     }
21.   }

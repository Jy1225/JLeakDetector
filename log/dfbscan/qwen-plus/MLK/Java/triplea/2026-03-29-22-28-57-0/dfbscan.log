9.         rVal.add(rs.getString(1));
10.       }
11.       rs.close();
12.       ps.close();
13.       return rVal;
14.     } catch (final SQLException sqle) {
15.       throw new IllegalStateException("Error reading bad words", sqle);
16.     } finally {
17.       DbUtil.closeConnection(con);
18.     }
19.   }

16.         final FileInputStream fileInputStream = new FileInputStream(gameXmlFile);
17.         final InputStream gameXmlStream = new BufferedInputStream(fileInputStream)) {
18.       final DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
19.       factory.setValidating(true);
20.       // use a dummy game.dtd, this prevents the xml parser from adding default values
21.       final URL url = XmlUpdater.class.getResource("");
22.       final String system = url.toExternalForm();
23.       final Source xmlSource = new StreamSource(gameXmlStream, system);
24.       resultBuf = new ByteArrayOutputStream();
25.       trans.transform(xmlSource, new StreamResult(resultBuf));
26.     }
27.     gameXmlFile.renameTo(new File(gameXmlFile.getAbsolutePath() + ".backup"));
28.     final FileOutputStream outStream = new FileOutputStream(gameXmlFile);
29.     outStream.write(resultBuf.toByteArray());
30.     outStream.close();
31.     System.out.println("Successfully updated:" + gameXmlFile);
32.   }

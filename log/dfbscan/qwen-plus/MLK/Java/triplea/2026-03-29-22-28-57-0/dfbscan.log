1. public static Connection getConnection(final String url, final Properties props) {
2.     ensureDbIsSetup();
3.     final Connection conn;
4.     /*
5.      * The connection specifies create=true to cause
6.      * the database to be created. To remove the database,
7.      * remove the directory derbyDB and its contents.
8.      * The directory derbyDB will be created under
9.      * the directory that the system property
10.      * derby.system.home points to, or the current
11.      * directory if derby.system.home is not set.
12.      */
13.     try {
14.       conn = DriverManager.getConnection(url, props);
15.     } catch (final SQLException e) {
16.       throw new IllegalStateException("Could not create db connection", e);
17.     }
18.     ensureDbTablesAreCreated(conn);
19.     return conn;
20.   }
```


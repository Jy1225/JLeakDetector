13.       props.put("mail.smtp.starttls.enable", "true");
14.       props.put("mail.smtp.starttls.required", "true");
15.     }
16.     props.put("mail.smtp.host", getHost());
17.     props.put("mail.smtp.port", getPort());
18.     props.put("mail.smtp.connectiontimeout", m_timeout);
19.     props.put("mail.smtp.timeout", m_timeout);
20.     final String to = m_toAddress;
21.     final String from = "noreply@triplea-game.org";
22.     // todo get the turn and player number from the game data
23.     try {
24.       final Session session = Session.getInstance(props, null);
25.       final MimeMessage mimeMessage = new MimeMessage(session);
26.       // Build the message fields one by one:
27.       // priority
28.       mimeMessage.setHeader("X-Priority", "3 (Normal)");
29.       // from
30.       mimeMessage.setFrom(new InternetAddress(from));
31.       // to address
32.       final StringTokenizer toAddresses = new StringTokenizer(to, " ", false);
33.       while (toAddresses.hasMoreTokens()) {
34.         mimeMessage.addRecipient(Message.RecipientType.TO, new InternetAddress(toAddresses.nextToken().trim()));
35.       }
36.       // subject

21.     final int thumbHeight = (int) (baseImg.getHeight(null) * scale);
22.     // based on code from
23.     // http://www.geocities.com/marcoschmidt.geo/java-save-jpeg-thumbnail.html
24.     // draw original image to thumbnail image object and

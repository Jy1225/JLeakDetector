1. @Override
2.     public void run() {
3.       try {
4.         socketChannel.register(acceptorSelector, SelectionKey.OP_ACCEPT);
5.       } catch (final ClosedChannelException e) {
6.         logger.log(Level.SEVERE, "socket closed", e);
7.         shutDown();
8.       }
9.       while (!shutdown) {
10.         try {
11.           acceptorSelector.select();
12.         } catch (final IOException e) {
13.           logger.log(Level.SEVERE, "Could not accept on server", e);
14.           shutDown();
15.         }
16.         if (shutdown) {
17.           continue;
18.         }
19.         final Set<SelectionKey> keys = acceptorSelector.selectedKeys();
20.         final Iterator<SelectionKey> iter = keys.iterator();
21.         while (iter.hasNext()) {
22.           final SelectionKey key = iter.next();
23.           iter.remove();
24.           if (key.isAcceptable() && key.isValid()) {
25.             final ServerSocketChannel serverSocketChannel = (ServerSocketChannel) key.channel();
26.             // Accept the connection and make it non-blocking
27.             SocketChannel socketChannel = null;
28.             try {
29.               socketChannel = serverSocketChannel.accept();
30.               if (socketChannel == null) {
31.                 continue;
32.               }
33.               socketChannel.configureBlocking(false);
34.               socketChannel.socket().setKeepAlive(true);
35.             } catch (final IOException e) {
36.               logger.log(Level.FINE, "Could not accept channel", e);
37.               try {
38.                 if (socketChannel != null) {
39.                   socketChannel.close();
40.                 }
41.               } catch (final IOException e2) {
42.                 logger.log(Level.FINE, "Could not close channel", e2);
43.               }
44.               continue;
45.             }
46.             // we are not accepting connections
47.             if (!acceptNewConnection) {
48.               try {
49.                 socketChannel.close();
50.               } catch (final IOException e) {
51.                 logger.log(Level.FINE, "Could not close channel", e);
52.               }
53.               continue;
54.             }
55.             final ServerQuarantineConversation conversation =
56.                 new ServerQuarantineConversation(loginValidator, socketChannel, nioSocket, ServerMessenger.this);
57.             nioSocket.add(socketChannel, conversation);
58.           } else if (!key.isValid()) {
59.             key.cancel();
60.           }
61.         }
62.       }
63.     }

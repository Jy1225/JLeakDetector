32.         if (!existing.contains("BANNED_MACS")) {
33.           final Statement s = conn.createStatement();
34.           s.execute("create table banned_macs" + "(" + "mac varchar(40) NOT NULL PRIMARY KEY, " + "ban_till timestamp  "

29.           .addTextBody("forum", forumId)
30.           .addTextBody("topic_id", m_topicId)
31.           .addTextBody("XOOPS_TOKEN_REQUEST", xoopsTokenRequest)
32.           .addTextBody("xoops_upload_file[]", "userfile")
33.           .addTextBody("contents_submit", "Submit")
34.           .addTextBody("doxcode", "1")
35.           .addTextBody("dosmiley", "1")
36.           .addTextBody("dohtml", "1")
37.           .addTextBody("dobr", "1")
38.           .addTextBody("editor", "dhtmltextarea");
39.       if (m_includeSaveGame && m_saveGameFile != null) {
40.         builder.addBinaryBody("userfile", m_saveGameFile, ContentType.APPLICATION_OCTET_STREAM, m_saveGameFileName);
41.       }
42.       HttpEntity entity = builder.build();
43.       HttpPost httpPost = new HttpPost(WAR_CLUB_FORUM_URL + "/post.php");
44.       HttpProxy.addProxy(httpPost);
45.       httpPost.setEntity(entity);
46. 
47.       try (CloseableHttpResponse response = client.execute(httpPost, httpContext)) {
48.         final int status = response.getStatusLine().getStatusCode();
49.         if (status != HttpURLConnection.HTTP_OK) {
50.           throw new Exception("Posting summary failed, the server returned status: " + status);
51.         }
52.         final String body = Util.getStringFromInputStream(response.getEntity().getContent());
53.         if (!body.toLowerCase().contains("thanks for your submission!")) {
54.           throw new Exception("Posting summary failed, the server didn't respond with thank you message");
55.         }
56.         m_turnSummaryRef =
57.             "www.tripleawarclub.org/modules/newbb/viewtopic.php?topic_id=" + m_topicId + "&forum=" + forumId;
58.       }
59.       // now logout, this is just to be nice, so we don't care if this fails
60.       try {
61.         httpGet = new HttpGet("http://www.tripleawarclub.org/user.php?op=logout");
62.         HttpProxy.addProxy(httpGet);
63.         client.execute(httpGet, httpContext);
64.       } catch (Exception e) {
65.         ClientLogger.logQuietly("Failed to log out", e);
66.       }
67.     } catch (final Exception e) {
68.       m_turnSummaryRef = e.getMessage();
69.       ClientLogger.logQuietly(e);
70.       return false;
71.     }
72.     return true;
73.   }

15.                   availableGames,
16.                   mapNamePropertyList);
17.               if (added && map.getName().length() > 4) {
18.                 availableMapFolderOrZipNames
19.                     .add(map.getName().substring(0, map.getName().length() - ZIP_EXTENSION.length()));
20.               }
21.             } catch (final URISyntaxException e) {
22.               // only happens when URI couldn't be build and therefore no entry was added. That's fine
23.             }
24.           }
25.         }
26.         // we have to close the loader to allow files to be deleted on windows
27.         zis.closeEntry();
28.         entry = zis.getNextEntry();

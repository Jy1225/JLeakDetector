1. @Override
2.   public DBUser getUserByName(final String userName) {
3.     final String sql = "select * from ta_users where username = ?";
4.     final Connection con = connectionSupplier.get();
5.     try {
6.       final PreparedStatement ps = con.prepareStatement(sql);
7.       ps.setString(1, userName);
8.       final ResultSet rs = ps.executeQuery();
9.       if (!rs.next()) {
10.         return null;
11.       }
12.       final DBUser user = new DBUser(
13.           new DBUser.UserName(rs.getString("username")),
14.           new DBUser.UserEmail(rs.getString("email")),
15.           rs.getBoolean("admin") ? DBUser.Role.ADMIN : DBUser.Role.NOT_ADMIN);
16.       rs.close();
17.       ps.close();
18.       return user;
19.     } catch (final SQLException sqle) {
20.       throw new IllegalStateException("Error getting user:" + userName, sqle);
21.     } finally {
22.       DbUtil.closeConnection(con);
23.     }
24.   }

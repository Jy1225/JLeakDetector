94.             continue;
95.           }
96.           if (thisTerritoryConnections.contains(otherTerritory)) {
97.             continue;
98.           }
99.           if (connections.get(otherTerritory) != null && connections.get(otherTerritory).contains(territory)) {
100.             continue;
101.           }
102.           for (final Area otherArea : territoryAreas.get(otherTerritory)) {
103.             final Area testArea = new Area(scaledShape);
104.             testArea.intersect(otherArea);
105.             if (!testArea.isEmpty() && sizeOfArea(testArea) > minOverlap) {
106.               thisTerritoryConnections.add(otherTerritory);
107.             }
108.           }
109.         }
110.         connections.put(territory, thisTerritoryConnections);
111.       }
112.     }
113.     if (JOptionPane.showConfirmDialog(null, "Do you also want to create the Territory Definitions?",
114.         "Territory Definitions", 1) == 0) {
115.       final String waterString = JOptionPane.showInputDialog(null,
116.           "Enter a string or regex that determines if the territory is Water? \r\n(e.g.: "
117.               + Util.TERRITORY_SEA_ZONE_INFIX + ")",
118.           Util.TERRITORY_SEA_ZONE_INFIX);
119.       territoryDefinitions = doTerritoryDefinitions(allTerritories, waterString);
120.     }
121.     try {
122.       final String fileName = new FileSave("Where To Save connections.txt ? (cancel to print to console)",
123.           "connections.txt", mapFolderLocation).getPathString();
124.       final StringBuffer connectionsString = convertToXml(connections);
125.       if (fileName == null) {
126.         System.out.println();
127.         if (territoryDefinitions != null) {
128.           System.out.println(territoryDefinitions.toString());
129.         }
130.         System.out.println(connectionsString.toString());
131.       } else {
132.         final FileOutputStream out = new FileOutputStream(fileName);
133.         if (territoryDefinitions != null) {
134.           out.write(String.valueOf(territoryDefinitions).getBytes());
135.         }
136.         out.write(String.valueOf(connectionsString).getBytes());
137.         out.flush();
138.         out.close();
139.         System.out.println("Data written to :" + new File(fileName).getCanonicalPath());
140.       }
141.     } catch (final Exception ex) {
142.       ex.printStackTrace();
143.     }
144.   }

8.             + m_readWriteLock.isWriteLockedByCurrentThread() + " Has Queued Threads: "
9.             + m_readWriteLock.hasQueuedThreads() + " Is Write Locked: " + m_readWriteLock.isWriteLocked()
10.             + " toString: " + m_readWriteLock.toString());
11.       } else {
12.         HeadlessGameServer.log("Could not block delegate execution. Read Lock count: "
13.             + m_readWriteLock.getReadLockCount() + " Write Hold count: " + m_readWriteLock.getWriteHoldCount()
14.             + " Queue Length: " + m_readWriteLock.getQueueLength() + " Current Thread Has Lock: "
15.             + m_readWriteLock.isWriteLockedByCurrentThread() + " Has Queued Threads: "
16.             + m_readWriteLock.hasQueuedThreads() + " Is Write Locked: " + m_readWriteLock.isWriteLocked()
17.             + " toString: " + m_readWriteLock.toString());
18.       }
19.     } else {
20.       if (sm_logger.isLoggable(Level.FINE)) {
21.         sm_logger.fine(Thread.currentThread().getName() + " block delegate execution.");
22.       }
23.     }
24.     return rVal;
25.   }

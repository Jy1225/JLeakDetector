1. @Override
2.   public void startGame(final IGame game, final Set<IGamePlayer> players, final boolean headless)
3.       throws InvocationTargetException {
4.     this.game = game;
5.     if (game.getData().getDelegateList().getDelegate("edit") == null) {
6.       // An evil hack: instead of modifying the XML, force an EditDelegate by adding one here
7.       final EditDelegate delegate = new EditDelegate();
8.       delegate.initialize("edit", "edit");
9.       game.getData().getDelegateList().addDelegate(delegate);
10.       if (game instanceof ServerGame) {
11.         ((ServerGame) game).addDelegateMessenger(delegate);
12.       }
13.     }
14.     final LocalPlayers localPlayers = new LocalPlayers(players);
15.     if (headless) {
16.       final IUIContext uiContext = new HeadlessUIContext();
17.       uiContext.setDefaultMapDir(game.getData());
18.       uiContext.setLocalPlayers(localPlayers);
19.       display = new HeadlessDisplay();
20.       soundChannel = new HeadlessSoundChannel();
21.       game.addDisplay(display);
22.       game.addSoundChannel(soundChannel);
23. 
24.       // technically not needed because we won't have any "local human players" in a headless game.
25.       connectPlayers(players, null);
26.     } else {
27.       try {
28.         SwingUtilities.invokeAndWait(() -> {
29.           final TripleAFrame frame;
30.           frame = new TripleAFrame(game, localPlayers);
31.           display = new TripleADisplay(frame);
32.           game.addDisplay(display);
33.           soundChannel = new DefaultSoundChannel(localPlayers);
34.           game.addSoundChannel(soundChannel);
35.           frame.setSize(700, 400);
36.           frame.setVisible(true);
37.           ClipPlayer.play(SoundPath.CLIP_GAME_START);
38.           connectPlayers(players, frame);
39.           frame.setExtendedState(Frame.MAXIMIZED_BOTH);
40.           frame.toFront();
41.         });
42.       } catch (InterruptedException e) {
43.         ClientLogger.logQuietly(e);
44.       }
45.     }
46. 
47.   }

2.     final GameData gameData = printData.getData();
3.     final Collection<Territory> terrCollection =
4.         Match.getMatches(gameData.getMap().getTerritories(), Matches.territoryHasUnitsOwnedBy(player));
5.     Iterator<Territory> terrIterator = terrCollection.iterator();
6.     Iterator<UnitType> availableUnits = gameData.getUnitTypeList().iterator();
7.     while (terrIterator.hasNext()) {
8.       final Territory currentTerritory = terrIterator.next();
9.       final UnitCollection unitsHere = currentTerritory.getUnits();
10.       final List<Map<UnitType, Integer>> unitPairs = new ArrayList<>();
11.       while (availableUnits.hasNext()) {
12.         final UnitType currentUnit = availableUnits.next();
13.         final int amountHere = unitsHere.getUnitCount(currentUnit, player);
14.         final Map<UnitType, Integer> innerMap = new HashMap<>();
15.         innerMap.put(currentUnit, amountHere);
16.         unitPairs.add(innerMap);
17.       }
18.       infoMap.put(currentTerritory, unitPairs);
19.       availableUnits = gameData.getUnitTypeList().iterator();
20.     }
21.     FileWriter countryFileWriter = null;
22.     final File outFile = new File(printData.getOutDir(), player.getName() + ".csv");
23.     try {
24.       countryFileWriter = new FileWriter(outFile, true);
25.       // Print Title
26.       final int numUnits = gameData.getUnitTypeList().size();
27.       for (int i = 0; i < numUnits / 2 - 1 + numUnits % 2; i++) {
28.         countryFileWriter.write(",");
29.       }
30.       countryFileWriter.write("Setup Chart for the " + player.getName());
31.       for (int i = 0; i < numUnits / 2 - numUnits % 2; i++) {
32.         countryFileWriter.write(",");
33.       }
34.       countryFileWriter.write("\r\n");
35.       // Print Unit Types
36.       final Iterator<UnitType> unitIterator = gameData.getUnitTypeList().iterator();
37.       countryFileWriter.write(",");
38.       while (unitIterator.hasNext()) {
39.         final UnitType currentType = unitIterator.next();
40.         countryFileWriter.write(currentType.getName() + ",");
41.       }
42.       countryFileWriter.write("\r\n");
43.       // Print Territories and Info
44.       terrIterator =
45.           Match.getMatches(gameData.getMap().getTerritories(), Matches.territoryHasUnitsOwnedBy(player)).iterator();
46.       while (terrIterator.hasNext()) {
47.         final Territory currentTerritory = terrIterator.next();
48.         countryFileWriter.write(currentTerritory.getName());
49.         final List<Map<UnitType, Integer>> currentList = infoMap.get(currentTerritory);
50.         final Iterator<Map<UnitType, Integer>> mapIterator = currentList.iterator();
51.         while (mapIterator.hasNext()) {
52.           final Map<UnitType, Integer> currentMap = mapIterator.next();
53.           final Iterator<UnitType> unitTypeIter = currentMap.keySet().iterator();
54.           while (unitTypeIter.hasNext()) {
55.             final UnitType unitTypeHere = unitTypeIter.next();
56.             final int here = currentMap.get(unitTypeHere);
57.             countryFileWriter.write("," + here);
58.           }
59.         }
60.         countryFileWriter.write("\r\n");
61.       }
62.       countryFileWriter.close();
63.     } catch (final IOException e) {
64.       ClientLogger.logError("Failed Saving to File " + outFile.toString(), e);
65.     }
66.   }
```

21.     final int thumbHeight = (int) (baseImg.getHeight(null) * scale);
22.     // based on code from
23.     // http://www.geocities.com/marcoschmidt.geo/java-save-jpeg-thumbnail.html
24.     // draw original image to thumbnail image object and
25.     // scale it to the new size on-the-fly
26.     final BufferedImage thumbImage = new BufferedImage(thumbWidth, thumbHeight, BufferedImage.TYPE_INT_RGB);
27.     final Graphics2D graphics2D = thumbImage.createGraphics();
28.     graphics2D.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BILINEAR);
29.     graphics2D.drawImage(baseImg, 0, 0, thumbWidth, thumbHeight, null);
30.     // save thumbnail image to OUTFILE
31.     final File file = new File(new File(mapFile.getPath()).getParent() + File.separatorChar + "smallMap.jpeg");
32.     final FileImageOutputStream out = new FileImageOutputStream(file);

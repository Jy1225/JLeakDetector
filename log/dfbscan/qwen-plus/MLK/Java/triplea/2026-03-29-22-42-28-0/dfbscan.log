1. protected void saveToFile(final PrintGenerationData printData, final Map<UnitType, UnitAttachment> unitInfoMap) {
2.     FileWriter unitInformation = null;
3.     final PrintGenerationData printData1 = printData;
4.     data = printData1.getData();
5.     final Map<UnitType, UnitAttachment> unitInfoMap1 = unitInfoMap;
6.     final Iterator<UnitType> unitTypeIterator = unitInfoMap1.keySet().iterator();
7.     printData1.getOutDir().mkdir();
8.     final File outFile = new File(printData1.getOutDir(), "General Information.csv");
9.     try {
10.       unitInformation = new FileWriter(outFile);
11.       for (int i = 0; i < 8; i++) {
12.         unitInformation.write(",");
13.       }
14.       unitInformation.write("Unit Information");
15.       for (int i = 10; i < 20; i++) {
16.         unitInformation.write(",");
17.       }
18.       unitInformation.write("\r\n");
19.       unitInformation.write("Unit,Cost,Movement,Attack,Defense,CanBlitz,Artillery?,ArtillerySupportable?"
20.           + ",Can Produce Units?,Marine?,Transport Cost,AA Gun?,Air Unit?,Strategic Bomber?,Carrier Cost,"
21.           + "Sea Unit?,Hit Points?,Transport Capacity,Carrier Capacity,Submarine?,Destroyer?");
22.       unitInformation.write("\r\n");
23.       while (unitTypeIterator.hasNext()) {
24.         final UnitType currentType = unitTypeIterator.next();
25.         final UnitAttachment currentAttachment = unitInfoMap1.get(currentType);
26.         if (currentType.getName().equals(Constants.UNIT_TYPE_AAGUN)) {
27.           unitInformation.write(currentType.getName() + ",");
28.         } else {
29.           unitInformation.write(capitalizeFirst(currentType.getName()) + ",");
30.         }
31.         unitInformation.write(getCostInformation(currentType) + ",");
32.         unitInformation.write(currentAttachment.getMovement(PlayerID.NULL_PLAYERID) + ","
33.             + currentAttachment.getAttack(PlayerID.NULL_PLAYERID) + ","
34.             + currentAttachment.getDefense(PlayerID.NULL_PLAYERID) + ","
35.             + (currentAttachment.getCanBlitz(PlayerID.NULL_PLAYERID) == false ? "-" : "true") + ","
36.             + (currentAttachment.getArtillery() == false ? "-" : "true") + ","
37.             + (currentAttachment.getArtillerySupportable() == false ? "-" : "true") + ","
38.             + (currentAttachment.getCanProduceUnits() == false ? "-" : "true") + ","
39.             + (currentAttachment.getIsMarine() == 0 ? "-" : currentAttachment.getIsMarine()) + ","
40.             + (currentAttachment.getTransportCost() == -1 ? "-" : currentAttachment.getTransportCost()) + ","
41.             + (Matches.unitTypeIsAaForAnything().match(currentType) == false ? "-" : "true") + ","
42.             + (currentAttachment.getIsAir() == false ? "-" : "true") + ","
43.             + (currentAttachment.getIsStrategicBomber() == false ? "-" : "true") + ","
44.             + (currentAttachment.getCarrierCost() == -1 ? "-" : currentAttachment.getCarrierCost()) + ","
45.             + (currentAttachment.getIsSea() == false ? "-" : "true") + "," + (currentAttachment.getHitPoints()) + ","
46.             + (currentAttachment.getTransportCapacity() == -1 ? "-" : currentAttachment.getTransportCapacity()) + ","
47.             + (currentAttachment.getCarrierCapacity() == -1 ? "-" : currentAttachment.getCarrierCapacity()) + ","
48.             + (currentAttachment.getIsSub() == false ? "-" : "true") + ","
49.             + (currentAttachment.getIsDestroyer() == false ? "-" : "true"));
50.         unitInformation.write("\r\n");
51.       }
52.       unitInformation.write("\r\n");
53.       unitInformation.close();
54.     } catch (final IOException e) {
55.       ClientLogger.logError("There was an error while trying to save File " + outFile.toString(), e);
56.     }
57.   }

40.       text.append("\n");
41.       text.append("TripleA Engine Version: ,");
42.       text.append(ClientContext.engineVersion() + ",");
43.       text.append("\n");
44.       text.append("Game Name: ,");
45.       text.append(gameData.getGameName() + ",");
46.       text.append("\n");
47.       text.append("Game Version: ,");
48.       text.append(gameData.getGameVersion() + ",");
49.       text.append("\n");
50.       text.append("\n");
51.       text.append("Current Round: ,");
52.       text.append(currentRound + ",");
53.       text.append("\n");
54.       text.append("Number of Players: ,");
55.       text.append(statPanel.getPlayers().size() + ",");
56.       text.append("\n");
57.       text.append("Number of Alliances: ,");
58.       text.append(statPanel.getAlliances().size() + ",");
59.       text.append("\n");
60.       text.append("\n");
61.       text.append("Turn Order: ,");
62.       text.append("\n");

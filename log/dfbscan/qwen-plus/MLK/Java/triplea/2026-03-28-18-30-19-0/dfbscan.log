100.             // ignore malformed input
101.           }
102.         }
103.         final String height = JOptionPane.showInputDialog(null,
104.             "Enter the unit's image height in pixels (unscaled / without zoom).\r\n(e.g. 48)");
105.         if (height != null) {
106.           try {
107.             placeHeight = (int) (unitZoomPercent * Integer.parseInt(height));
108.           } catch (final NumberFormatException ex) {
109.             // ignore malformed input
110.           }
111.         }
112.         placeDimensionsSet = true;
113.       } catch (final Exception ex) {
114.         ClientLogger.logQuietly(ex);
115.       }
116.     }
117.     try {
118.       // makes TripleA read all the text data files for the map.
119.       mapData = new MapData(mapDir);
120.     } catch (final Exception ex) {
121.       JOptionPane.showMessageDialog(null, new JLabel(
122.           "Could not find map. Make sure it is in finalized location and contains centers.txt and polygons.txt"));
123.       System.out.println("Caught Exception.");
124.       System.out.println("Could be due to some missing text files.");
125.       System.out.println("Or due to the map folder not being in the right location.");
126.       ex.printStackTrace();
127.       System.exit(0);
128.     }
129.     textOptionPane.show();
130.     textOptionPane.appendNewLine("Place Dimensions in pixels, being used: " + placeWidth + "x" + placeHeight + "\r\n");
131.     textOptionPane.appendNewLine("Calculating, this may take a while...\r\n");
132.     final Iterator<String> terrIter = mapData.getTerritories().iterator();
133.     while (terrIter.hasNext()) {
134.       final String name = terrIter.next();
135.       List<Point> points;
136.       if (mapData.hasContainedTerritory(name)) {
137.         final Set<Polygon> containedPolygons = new HashSet<>();
138.         for (final String containedName : mapData.getContainedTerritory(name)) {
139.           containedPolygons.addAll(mapData.getPolygons(containedName));
140.         }
141.         points = getPlacementsStartingAtTopLeft(mapData.getPolygons(name), mapData.getBoundingRect(name),
142.             mapData.getCenter(name), containedPolygons);
143.         placements.put(name, points);
144.       } else {
145.         points = getPlacementsStartingAtMiddle(mapData.getPolygons(name), mapData.getBoundingRect(name),
146.             mapData.getCenter(name));
147.         placements.put(name, points);
148.       }
149.       textOptionPane.appendNewLine(name + ": " + points.size());
150.     } // while
151.     textOptionPane.appendNewLine("\r\nAll Finished!");
152.     textOptionPane.countDown();
153.     try {
154.       final String fileName =
155.           new FileSave("Where To Save place.txt ?", "place.txt", mapFolderLocation).getPathString();
156.       if (fileName == null) {
157.         textOptionPane.appendNewLine("You chose not to save, Shutting down");
158.         textOptionPane.dispose();
159.         System.exit(0);
160.       }
161.       PointFileReaderWriter.writeOneToMany(new FileOutputStream(fileName), placements);
162.       textOptionPane.appendNewLine("Data written to :" + new File(fileName).getCanonicalPath());
163.     } catch (final Exception ex) {
164.       ex.printStackTrace();
165.       textOptionPane.dispose();
166.       System.exit(0);
167.     }
168.     textOptionPane.dispose();
169.     // shut down program when done.
170.     System.exit(0);
171.   }

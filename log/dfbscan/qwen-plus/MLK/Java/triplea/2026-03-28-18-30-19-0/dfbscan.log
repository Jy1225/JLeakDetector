109.           text.append(pr.getName()).append(",").append(pr.getResults().keySet().iterator().next().getName()).append(",")
110.               .append(pr.getResults().getInt(pr.getResults().keySet().iterator().next())).append(",").append(costString)
111.               .append(",");
112.           text.append("\n");

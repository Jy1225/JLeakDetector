6.     final int totalBitsPerBase64Digit = 8;
7.     final int byteLengthForDesiredEntropy =
8.         (base64DigitCountFor160BitEntropy * dataBitsPerBase64Digit / totalBitsPerBase64Digit) + 1;
9. 
10.     final byte[] randomBytes = new byte[byteLengthForDesiredEntropy];
11.     fillRandom(randomBytes);
12.     final byte[] encodedMasterPassword = Base64.getEncoder().encode(randomBytes);
13.     scrub(randomBytes);
14.     final char[] masterPassword = decodeBytesToChars(encodedMasterPassword);
15.     scrub(encodedMasterPassword);
16.     return masterPassword;
17.   }

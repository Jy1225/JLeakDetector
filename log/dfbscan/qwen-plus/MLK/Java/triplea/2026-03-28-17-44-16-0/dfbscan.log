8.     candidates.add(new File(ClientFileSystemHelper.getUserMapsFolder(), dirName + File.separator + "map"));
9.     candidates.add(new File(ClientFileSystemHelper.getUserMapsFolder(), dirName));
10.     candidates.addAll(getMapZipFileCandidates(mapName));
11. 
12.     final Optional<File> match = candidates.stream().filter(file -> file.exists()).findFirst();
13.     if (!match.isPresent()) {
14.       // if we get no results, we will eventually prompt the user to download the map
15.       return new ArrayList<>();
16.     }
17.     ClientLogger.logQuietly("Loading map: " + mapName + ", from: " + match.get().getAbsolutePath());
18. 
19.     final List<String> rVal = new ArrayList<>();

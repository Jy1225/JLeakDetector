1. @Override
2.       public void actionPerformed(final ActionEvent ae) {
3.         JOptionPane.showMessageDialog(TripleAFrame.this,
4.             "Please first left click on the spot you want to save from, Then right click and select 'Save Game From "
5.                 + "History'"
6.                 + "\n\nIt is recommended that when saving the game from the History panel:"
7.                 + "\n * Your CURRENT GAME is at the start of some player's turn, and that no moves have been made and "
8.                 + "no actions taken yet."
9.                 + "\n * The point in HISTORY that you are trying to save at, is at the beginning of a player's turn, "
10.                 + "or the beginning of a round."
11.                 + "\nSaving at any other point, could potentially create errors."
12.                 + "\nFor example, saving while your current game is in the middle of a move or battle phase will "
13.                 + "always create errors in the savegame."
14.                 + "\nAnd you will also get errors in the savegame if you try to create a save at a point in history "
15.                 + "such as a move or battle phase.",
16.             "Save Game from History", JOptionPane.INFORMATION_MESSAGE);
17.         data.acquireReadLock();
18.         try {
19.           final File f = TripleAMenuBar.getSaveGameLocation(TripleAFrame.this);
20.           if (f != null) {
21.             try (FileOutputStream fout = new FileOutputStream(f)) {
22.               final GameData datacopy = GameDataUtils.cloneGameData(data, true);
23.               datacopy.getHistory().gotoNode(historyPanel.getCurrentPopupNode());
24.               datacopy.getHistory().removeAllHistoryAfterNode(historyPanel.getCurrentPopupNode());
25.               // TODO: the saved current delegate is still the current delegate,
26.               // rather than the delegate at that history popup node
27.               // TODO: it still shows the current round number, rather than the round at the history popup node
28.               // TODO: this could be solved easily if rounds/steps were changes,
29.               // but that could greatly increase the file size :(
30.               // TODO: this also does not undo the runcount of each delegate step
31.               @SuppressWarnings("unchecked")
32.               final Enumeration<TreeNode> enumeration =
33.                   ((DefaultMutableTreeNode) datacopy.getHistory().getRoot()).preorderEnumeration();
34.               enumeration.nextElement();
35.               int round = 0;
36.               String stepDisplayName = datacopy.getSequence().getStep(0).getDisplayName();
37.               PlayerID currentPlayer = datacopy.getSequence().getStep(0).getPlayerID();
38.               while (enumeration.hasMoreElements()) {
39.                 final HistoryNode node = (HistoryNode) enumeration.nextElement();
40.                 if (node instanceof Round) {
41.                   round = Math.max(0, ((Round) node).getRoundNo() - datacopy.getSequence().getRoundOffset());
42.                   currentPlayer = null;
43.                   stepDisplayName = node.getTitle();
44.                 } else if (node instanceof Step) {
45.                   currentPlayer = ((Step) node).getPlayerID();
46.                   stepDisplayName = node.getTitle();
47.                 }
48.               }
49.               datacopy.getSequence().setRoundAndStep(round, stepDisplayName, currentPlayer);
50.               GameDataManager.saveGame(fout, datacopy);
51.               JOptionPane.showMessageDialog(TripleAFrame.this, "Game Saved", "Game Saved",
52.                   JOptionPane.INFORMATION_MESSAGE);
53.             } catch (final IOException e) {
54.               ClientLogger.logQuietly(e);
55.             }
56.           }
57.         } finally {
58.           data.releaseReadLock();
59.         }
60.         historyPanel.clearCurrentPopupNode();
61.       }

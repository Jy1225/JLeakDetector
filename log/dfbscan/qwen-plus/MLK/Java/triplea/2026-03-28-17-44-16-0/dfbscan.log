1. protected void saveToFile(final PrintGenerationData printData) {
2.     final GameData gameData = printData.getData();
3.     Iterator<PlayerID> playerIterator = gameData.getPlayerList().iterator();
4.     while (playerIterator.hasNext()) {
5.       final PlayerID currentPlayer = playerIterator.next();
6.       final Iterator<Resource> resourceIterator = gameData.getResourceList().getResources().iterator();
7.       final Map<Resource, Integer> resourceMap = new HashMap<>();
8.       while (resourceIterator.hasNext()) {
9.         final Resource currentResource = resourceIterator.next();
10.         final int amountOfResource = currentPlayer.getResources().getQuantity(currentResource);
11.         resourceMap.put(currentResource, amountOfResource);
12.       }
13.       infoMap.put(currentPlayer, resourceMap);
14.     }
15.     FileWriter resourceWriter = null;
16.     try {
17.       final File outFile = new File(printData.getOutDir(), "General Information.csv");
18.       resourceWriter = new FileWriter(outFile, true);
19.       // Print Title
20.       final int numResources = gameData.getResourceList().size();
21.       for (int i = 0; i < numResources / 2 - 1 + numResources % 2; i++) {
22.         resourceWriter.write(",");
23.       }
24.       resourceWriter.write("Resource Chart");
25.       for (int i = 0; i < numResources / 2 - numResources % 2; i++) {
26.         resourceWriter.write(",");
27.       }
28.       resourceWriter.write("\r\n");
29.       // Print Resources
30.       final Iterator<Resource> resourceIterator = gameData.getResourceList().getResources().iterator();
31.       resourceWriter.write(",");
32.       while (resourceIterator.hasNext()) {
33.         final Resource currentResource = resourceIterator.next();
34.         resourceWriter.write(currentResource.getName() + ",");
35.       }
36.       resourceWriter.write("\r\n");
37.       // Print Player's and Resource Amount's
38.       playerIterator = gameData.getPlayerList().iterator();
39.       while (playerIterator.hasNext()) {
40.         final PlayerID currentPlayer = playerIterator.next();
41.         resourceWriter.write(currentPlayer.getName());
42.         final Map<Resource, Integer> resourceMap = infoMap.get(currentPlayer);
43.         final Iterator<Resource> resIterator = resourceMap.keySet().iterator();
44.         while (resIterator.hasNext()) {
45.           final Resource currentResource = resIterator.next();
46.           final int amountResource = resourceMap.get(currentResource);
47.           resourceWriter.write("," + amountResource);
48.         }
49.         resourceWriter.write("\r\n");
50.       }
51.       resourceWriter.write("\r\n");
52.       resourceWriter.close();
53.     } catch (final IOException e) {
54.       ClientLogger.logQuietly(e);

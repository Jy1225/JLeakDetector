7.     if (playerId != null) {
8.       folder += "_" + playerId.getName();
9.     }
10. 
11.     final URI clip = loadClip(folder).orElse(loadClip(clipName).orElse(null));
12.     // clip may still be null, we try to load all phases/all sound, for example: clipName = "phase_technology", folder =
13.     // "phase_technology_Japanese"
14. 
15.     if (clip != null) {
16.       (new Thread(() -> {
17.         try {
18.           Optional<InputStream> inputStream = UrlStreams.openStream(clip.toURL());
19.           if (inputStream.isPresent()) {
20.             final AudioDevice audioDevice = FactoryRegistry.systemRegistry().createAudioDevice();
21.             new AdvancedPlayer(inputStream.get(), audioDevice).play();
22.           }
23.         } catch (Exception e) {
24.           ClientLogger.logError("Failed to play: " + clip, e);
25.         }
26.       })).start();
27.     }
28.   }
```

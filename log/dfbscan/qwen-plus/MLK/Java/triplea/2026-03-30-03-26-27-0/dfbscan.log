10.       final boolean found = rs.next();
11.       if (found) {
12.         final Timestamp muteTill = rs.getTimestamp(2);
13.         result = muteTill.getTime();
14.         if (result < System.currentTimeMillis()) {
15.           logger.fine("Mute expired for:" + username);
16.           expired = true;
17.         }
18.       } else {
19.         result = -1;
20.       }
21.       rs.close();
22.       ps.close();
23.     } catch (final SQLException sqle) {
24.       throw new IllegalStateException("Error for testing muted username existence:" + username, sqle);
25.     } finally {
26.       DbUtil.closeConnection(con);
27.     }
28.     // If the mute has expired, allow the username
29.     if (expired) {
30.       removeMutedUsername(username);
31.       // Signal as not-muted
32.       result = -1;
33.     }
34.     return result;
35.   }

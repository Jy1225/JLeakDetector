1. public static void exec(final List<String> commands) {
2.     // System.out.println("Commands: " + commands);
3.     final ProcessBuilder builder = new ProcessBuilder(commands);
4.     // merge the streams, so we only have to start one reader thread
5.     builder.redirectErrorStream(true);
6.     try {
7.       final Process p = builder.start();
8.       final InputStream s = p.getInputStream();
9.       // we need to read the input stream to prevent possible
10.       // deadlocks
11.       final Thread t = new Thread(() -> {
12.         try (Scanner scanner = new Scanner(s)) {
13.           while (scanner.hasNextLine()) {
14.             System.out.println(scanner.nextLine());
15.           }
16.         }
17.       }, "Process output gobbler");
18.       t.setDaemon(true);
19.       t.start();
20.     } catch (final IOException e) {
21.       ClientLogger.logQuietly(e);
22.     }
23.   }

1. private static List<String> getPaths(final String mapName) {
2.     if (mapName == null) {
3.       return new ArrayList<>();
4.     }
5.     // find the primary directory/file
6.     final String dirName = File.separator + mapName;
7.     final List<File> candidates = new ArrayList<>();
8.     candidates.add(new File(ClientFileSystemHelper.getUserMapsFolder(), dirName + File.separator + "map"));
9.     candidates.add(new File(ClientFileSystemHelper.getUserMapsFolder(), dirName));
10.     candidates.addAll(getMapZipFileCandidates(mapName));
11. 
12.     final Optional<File> match = candidates.stream().filter(file -> file.exists()).findFirst();
13.     if (!match.isPresent()) {
14.       // if we get no results, we will eventually prompt the user to download the map
15.       return new ArrayList<>();
16.     }
17.     ClientLogger.logQuietly("Loading map: " + mapName + ", from: " + match.get().getAbsolutePath());
18. 
19.     final List<String> rVal = new ArrayList<>();
20.     rVal.add(match.get().getAbsolutePath());
21.     // find dependencies
22.     try (final URLClassLoader url = new URLClassLoader(new URL[] {match.get().toURI().toURL()})) {
23.       final URL dependencesUrl = url.getResource("dependencies.txt");
24.       if (dependencesUrl != null) {
25.         final java.util.Properties dependenciesFile = new java.util.Properties();
26. 
27.         final Optional<InputStream> inputStream = UrlStreams.openStream(dependencesUrl);
28.         if (inputStream.isPresent()) {
29.           try (final InputStream stream = inputStream.get()) {
30.             dependenciesFile.load(stream);
31.             final String dependencies = dependenciesFile.getProperty("dependencies");
32.             final StringTokenizer tokens = new StringTokenizer(dependencies, ",", false);
33.             while (tokens.hasMoreTokens()) {
34.               // add the dependencies recursivly
35.               rVal.addAll(getPaths(tokens.nextToken()));
36.             }
37.           }
38.         }
39.       }
40.     } catch (final Exception e) {
41.       ClientLogger.logQuietly(e);
42.       throw new IllegalStateException(e.getMessage());
43.     }
44.     return rVal;
45.   }

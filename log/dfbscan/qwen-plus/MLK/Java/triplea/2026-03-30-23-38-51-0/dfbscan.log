1. public static Collection<PropertiesDiceRoller> loadFromFile() {
2.     final List<PropertiesDiceRoller> rollers = new ArrayList<>();
3.     final File f = new File(ClientFileSystemHelper.getRootFolder(), "dice_servers");
4.     if (!f.exists()) {
5.       throw new IllegalStateException("No dice server folder:" + f);
6.     }
7.     final List<Properties> propFiles = new ArrayList<>();
8.     final File[] files = f.listFiles();
9.     for (final File file : files) {
10.       if (!file.isDirectory() && file.getName().endsWith(".properties")) {
11.         try {
12.           final Properties props = new Properties();
13.           try (final FileInputStream fin = new FileInputStream(file)) {
14.             props.load(fin);
15.             propFiles.add(props);
16.           }
17.         } catch (final IOException e) {
18.           System.out.println("error reading file:" + file);
19.           ClientLogger.logQuietly(e);
20.         }
21.       }
22.     }
23.     Collections.sort(propFiles, (o1, o2) -> {
24.       final int n1 = Integer.parseInt(o1.getProperty("order"));
25.       final int n2 = Integer.parseInt(o2.getProperty("order"));
26.       return n1 - n2;
27.     });
28.     for (final Properties prop : propFiles) {
29.       rollers.add(new PropertiesDiceRoller(prop));
30.     }
31.     return rollers;
32.   }

45.                 found = true;
46.               } catch (final NumberFormatException ex) {
47.                 // ignore malformed input
48.               }
49.             }
50.             if (line.contains(heightProperty)) {
51.               try {
52.                 height =
53.                     Integer.parseInt(line.substring(line.indexOf(heightProperty) + heightProperty.length()).trim());
54.                 found = true;
55.               } catch (final NumberFormatException ex) {
56.                 // ignore malformed input
57.               }
58.             }
59.           }
60.           reader2.close();
61.           i++;
62.           if (found) {
63.             final int result = JOptionPane.showConfirmDialog(new JPanel(),

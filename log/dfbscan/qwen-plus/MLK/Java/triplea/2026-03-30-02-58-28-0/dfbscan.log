17.     if (chooser.showSaveDialog(frame) != JOptionPane.OK_OPTION) {
18.       return;
19.     }
20.     final String xmlFile;
21.     try {
22.       gameData.acquireReadLock();
23.       final GameDataExporter exporter = new GameDataExporter(gameData);
24.       xmlFile = exporter.getXML();
25.     } finally {
26.       gameData.releaseReadLock();
27.     }
28.     try {
29.       try (final FileWriter writer = new FileWriter(chooser.getSelectedFile())) {
30.         writer.write(xmlFile);

66.                     + "\r\n Zoom = " + scale + ",  Width = " + width + ",  Height = " + height + ",    Result = ("
67.                     + ((int) (scale * width)) + "x" + ((int) (scale * height)) + ")",
68.                 "File Suggestion", 1);
69. 
70.             if (result == 0) {
71.               unitZoomPercent = scale;
72.               placeWidth = (int) (unitZoomPercent * width);
73.               placeHeight = (int) (unitZoomPercent * height);
74.               placeDimensionsSet = true;
75.             }
76.           }
77.         }
78.       } catch (final Exception ex) {
79.         ClientLogger.logQuietly(ex);
80.       }
81.     }
82.     if (!placeDimensionsSet || JOptionPane.showConfirmDialog(new JPanel(),
83.         "Placement Box Size already set (" + placeWidth + "x" + placeHeight + "), "
84.             + "do you wish to continue with this?\r\n"
85.             + "Select Yes to continue, Select No to override and change the size.",
86.         "Placement Box Size", JOptionPane.YES_NO_OPTION) == 1) {
87.       try {
88.         final String result = getUnitsScale();
89.         try {
90.           unitZoomPercent = Double.parseDouble(result.toLowerCase());
91.         } catch (final NumberFormatException ex) {
92.           // ignore malformed input
93.         }
94.         final String width = JOptionPane.showInputDialog(null,
95.             "Enter the unit's image width in pixels (unscaled / without zoom).\r\n(e.g. 48)");
96.         if (width != null) {
97.           try {
98.             placeWidth = (int) (unitZoomPercent * Integer.parseInt(width));
99.           } catch (final NumberFormatException ex) {
100.             // ignore malformed input
101.           }
102.         }
103.         final String height = JOptionPane.showInputDialog(null,
104.             "Enter the unit's image height in pixels (unscaled / without zoom).\r\n(e.g. 48)");
105.         if (height != null) {
106.           try {
107.             placeHeight = (int) (unitZoomPercent * Integer.parseInt(height));
108.           } catch (final NumberFormatException ex) {
109.             // ignore malformed input
110.           }
111.         }
112.         placeDimensionsSet = true;
113.       } catch (final Exception ex) {
114.         ClientLogger.logQuietly(ex);
115.       }
116.     }
117.     try {
118.       // makes TripleA read all the text data files for the map.
119.       mapData = new MapData(mapDir);
120.     } catch (final Exception ex) {

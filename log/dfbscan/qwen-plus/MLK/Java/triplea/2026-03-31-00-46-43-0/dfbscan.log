5.             + "<br>It will create a file containing the connections between territories, and optionally the territory "
6.             + "definitions as well. "
7.             + "<br>Copy and paste everything from this file into your game xml file (the 'map' section). "
8.             + "<br>The connections file can and Should Be Deleted when finished, because it is Not Needed and not read "
9.             + "by the engine. "
10.             + "</html>"));
11.     System.out.println("Select polygons.txt");
12.     File polyFile = null;
13.     if (mapFolderLocation != null && mapFolderLocation.exists()) {
14.       polyFile = new File(mapFolderLocation, "polygons.txt");
15.     }
16.     if (polyFile != null && polyFile.exists() && JOptionPane.showConfirmDialog(null,
17.         "A polygons.txt file was found in the map's folder, do you want to use it?", "File Suggestion", 1) == 0) {
18.       // yay
19.     } else {
20.       polyFile = new FileOpen("Select The polygons.txt file", mapFolderLocation, ".txt").getFile();
21.     }
22.     if (polyFile == null || !polyFile.exists()) {
23.       System.out.println("No polygons.txt Selected. Shutting down.");
24.       System.exit(0);
25.     }
26.     if (mapFolderLocation == null && polyFile != null) {
27.       mapFolderLocation = polyFile.getParentFile();
28.     }
29.     final Map<String, List<Area>> territoryAreas = new HashMap<>();
30.     Map<String, List<Polygon>> mapOfPolygons = null;
31.     try {
32.       final FileInputStream in = new FileInputStream(polyFile);
33.       mapOfPolygons = PointFileReaderWriter.readOneToManyPolygons(in);
34.       for (final String territoryName : mapOfPolygons.keySet()) {
35.         final List<Polygon> listOfPolygons = mapOfPolygons.get(territoryName);
36.         final List<Area> listOfAreas = new ArrayList<>();
37.         for (final Polygon p : listOfPolygons) {
38.           listOfAreas.add(new Area(p));
39.         }
40.         territoryAreas.put(territoryName, listOfAreas);
41.       }
42.     } catch (final IOException ex) {
43.       ClientLogger.logQuietly(ex);
44.     }
45.     if (!dimensionsSet) {
46.       final String lineWidth = JOptionPane.showInputDialog(null,
47.           "Enter the width of territory border lines on your map? \r\n(eg: 1, or 2, etc.)");
48.       try {
49.         final int lineThickness = Integer.parseInt(lineWidth);
50.         scalePixels = lineThickness * 4;
51.         minOverlap = scalePixels * 4;
52.         dimensionsSet = true;
53.       } catch (final NumberFormatException ex) {
54.         // ignore malformed input
55.       }
56.     }
57.     if (JOptionPane.showConfirmDialog(null,
58.         "Scale set to " + scalePixels + " pixels larger, and minimum overlap set to " + minOverlap + " pixels. \r\n"
59.             + "Do you wish to continue with this? \r\n"
60.             + "Select Yes to continue, Select No to override and change the size.",
61.         "Scale and Overlap Size", JOptionPane.YES_NO_OPTION) == 1) {
62.       final String scale = JOptionPane.showInputDialog(null,
63.           "Enter the number of pixels larger each territory should become? \r\n"
64.               + "(Normally 4x bigger than the border line width. eg: 4, or 8, etc)");
65.       try {
66.         scalePixels = Integer.parseInt(scale);
67.       } catch (final NumberFormatException ex) {
68.         // ignore malformed input
69.       }
70.       final String overlap = JOptionPane.showInputDialog(null,
71.           "Enter the minimum number of overlapping pixels for a connection? \r\n"
72.               + "(Normally 16x bigger than the border line width. eg: 16, or 32, etc.)");
73.       try {
74.         minOverlap = Integer.parseInt(overlap);
75.       } catch (final NumberFormatException ex) {
76.         // ignore malformed input
77.       }
78.     }
79.     final Map<String, Collection<String>> connections = new HashMap<>();
80.     System.out.println("Now Scanning for Connections");
81.     // sort so that they are in alphabetic order (makes xml's prettier and easier to update in future)
82.     final List<String> allTerritories =
83.         mapOfPolygons == null ? new ArrayList<>() : new ArrayList<>(mapOfPolygons.keySet());
84.     Collections.sort(allTerritories, new AlphanumComparator());
85.     final List<String> allAreas = new ArrayList<>(territoryAreas.keySet());
86.     Collections.sort(allAreas, new AlphanumComparator());
87.     for (final String territory : allTerritories) {
88.       final Set<String> thisTerritoryConnections = new LinkedHashSet<>();
89.       final List<Polygon> currentPolygons = mapOfPolygons.get(territory);
90.       for (final Polygon currentPolygon : currentPolygons) {
91.         final Shape scaledShape = scale(currentPolygon, scalePixels);
92.         for (final String otherTerritory : allAreas) {
93.           if (otherTerritory.equals(territory)) {
94.             continue;
95.           }
96.           if (thisTerritoryConnections.contains(otherTerritory)) {
97.             continue;
98.           }
99.           if (connections.get(otherTerritory) != null && connections.get(otherTerritory).contains(territory)) {
100.             continue;
101.           }
102.           for (final Area otherArea : territoryAreas.get(otherTerritory)) {
103.             final Area testArea = new Area(scaledShape);
104.             testArea.intersect(otherArea);
105.             if (!testArea.isEmpty() && sizeOfArea(testArea) > minOverlap) {
106.               thisTerritoryConnections.add(otherTerritory);
107.             }
108.           }
109.         }
110.         connections.put(territory, thisTerritoryConnections);
111.       }
112.     }
113.     if (JOptionPane.showConfirmDialog(null, "Do you also want to create the Territory Definitions?",
114.         "Territory Definitions", 1) == 0) {
115.       final String waterString = JOptionPane.showInputDialog(null,
116.           "Enter a string or regex that determines if the territory is Water? \r\n(e.g.: "
117.               + Util.TERRITORY_SEA_ZONE_INFIX + ")",
118.           Util.TERRITORY_SEA_ZONE_INFIX);
119.       territoryDefinitions = doTerritoryDefinitions(allTerritories, waterString);
120.     }
121.     try {
122.       final String fileName = new FileSave("Where To Save connections.txt ? (cancel to print to console)",
123.           "connections.txt", mapFolderLocation).getPathString();
124.       final StringBuffer connectionsString = convertToXml(connections);
125.       if (fileName == null) {
126.         System.out.println();
127.         if (territoryDefinitions != null) {
128.           System.out.println(territoryDefinitions.toString());
129.         }
130.         System.out.println(connectionsString.toString());
131.       } else {
132.         final FileOutputStream out = new FileOutputStream(fileName);
133.         if (territoryDefinitions != null) {
134.           out.write(String.valueOf(territoryDefinitions).getBytes());
135.         }
136.         out.write(String.valueOf(connectionsString).getBytes());
137.         out.flush();
138.         out.close();
139.         System.out.println("Data written to :" + new File(fileName).getCanonicalPath());
140.       }
141.     } catch (final Exception ex) {
142.       ex.printStackTrace();
143.     }
144.   }

7. 
8.     final CompletableFuture<T> promise = new CompletableFuture<>();
9.     final SwingWorker<T, ?> worker = new SwingWorker<T, Void>() {
10.       @Override
11.       protected T doInBackground() throws Exception {
12.         return task.call();
13.       }
14. 
15.       @Override
16.       protected void done() {
17.         try {
18.           promise.complete(get());
19.         } catch (final ExecutionException e) {
20.           promise.completeExceptionally(e.getCause());
21.         } catch (final InterruptedException e) {
22.           promise.completeExceptionally(e);
23.           Thread.currentThread().interrupt();
24.         }
25.       }
26.     };
27.     final ProgressDialog progressDialog = new ProgressDialog(frame, message);
28.     worker.addPropertyChangeListener(new SwingWorkerCompletionWaiter(progressDialog));
29.     worker.execute();
30.     return promise;
31.   }

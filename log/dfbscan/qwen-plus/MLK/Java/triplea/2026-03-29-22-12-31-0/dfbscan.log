19.       s.close();
20.       logger.fine("Connection test passed for host:" + host + " port:" + port);
21.       return null;
22.     } catch (final IOException e) {
23.       logger.fine("Connection test failed for host:" + host + " port:" + port + " reason:" + e.getMessage());

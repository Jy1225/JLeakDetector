1. private void removeMutedUsername(final String username) {
2.     logger.fine("Removing muted username:" + username);
3.     final Connection con = Database.getDerbyConnection();
4.     try {
5.       final PreparedStatement ps = con.prepareStatement("delete from muted_usernames where username = ?");
6.       ps.setString(1, username);
7.       ps.execute();
8.       ps.close();
9.       con.commit();
10.     } catch (final SQLException sqle) {
11.       throw new IllegalStateException("Error deleting muted username:" + username, sqle);
12.     } finally {
13.       DbUtil.closeConnection(con);
14.     }
15.   }
```

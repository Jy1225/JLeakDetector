1. @Override
2.   @SuppressWarnings("unchecked")
3.   // generics are compile time only, and lost during serialization
4.   public void loadCachedGamePropertiesInto(final GameData gameData) {
5.     final File cache = getCacheFile(gameData);
6.     try {
7.       if (cache.exists()) {
8.         final ObjectInputStream in = new ObjectInputStream(new FileInputStream(cache));
9.         final Map<String, Serializable> serializedMap = (Map<String, Serializable>) in.readObject();
10.         for (final IEditableProperty property : gameData.getProperties().getEditableProperties()) {
11.           final Serializable ser = serializedMap.get(property.getName());
12.           if (ser != null) {
13.             property.setValue(ser);
14.           }
15.         }
16.         in.close();
17.       }
18.     } catch (IOException | ClassNotFoundException e) {
19.       ClientLogger.logQuietly(e);
20.     }

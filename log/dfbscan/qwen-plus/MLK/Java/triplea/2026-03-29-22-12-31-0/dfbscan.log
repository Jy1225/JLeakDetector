1. private static GameData loadGameInSerializationFormat(
2.       final InputStream inputStream,
3.       final @Nullable String savegamePath)
4.       throws IOException {
5.     final ObjectInputStream input = new ObjectInputStream(new GZIPInputStream(inputStream));
6.     try {
7.       final Version readVersion = (Version) input.readObject();
8.       final boolean headless = HeadlessGameServer.headless();
9.       if (!readVersion.equals(ClientContext.engineVersion(), true)) {
10.         // a hack for now, but a headless server should not try to open any savegame that is not its version
11.         if (headless) {
12.           final String message = "Incompatible game save, we are: " + ClientContext.engineVersion()
13.               + "  Trying to load game created with: " + readVersion;
14.           HeadlessGameServer.sendChat(message);
15.           System.out.println(message);
16.           return null;
17.         }
18.         final String error = "<html>Incompatible engine versions, and no old engine found. We are: "
19.             + ClientContext.engineVersion() + " . Trying to load game created with: " + readVersion
20.             + "<br>To download the latest version of TripleA, Please visit "
21.             + UrlConstants.LATEST_GAME_DOWNLOAD_WEBSITE + "</html>";
22.         if (savegamePath == null) {
23.           throw new IOException(error);
24.         }
25.         // so, what we do here is try to see if our installed copy of triplea includes older jars with it that are the
26.         // same engine as was
27.         // used for this savegame, and if so try to run it
28.         try {
29.           final String newClassPath = GameRunner.findOldJar(readVersion, true);
30.           // ask user if we really want to do this?
31.           final String messageString = "<html>This TripleA engine is version " + ClientContext.engineVersion()
32.               + " and you are trying to open a savegame made with version " + readVersion.toString()
33.               + "<br>However, this TripleA cannot open any savegame made by any engine other than engines with the "
34.               + "same first three version numbers as it (x_x_x_x)."
35.               + "<br><br>TripleA now comes with older engines included with it, and has found the engine to run this "
36.               + "savegame. This is a new feature and is in 'beta' stage."
37.               + "<br>It will attempt to run a new instance of TripleA using the older engine jar file, and this "
38.               + "instance will only be able to play this savegame."
39.               + "<br><b>You may choose to either Close or Keep the current instance of TripleA!</b> (If hosting, you "
40.               + "must close it). Please report any bugs or issues."
41.               + "<br><br>Do you wish to continue?</html>";
42.           final String yesClose = "Yes & Close Current";
43.           final String yesOpen = "Yes & Do Not Close";
44.           final String cancel = "Cancel";
45.           final Object[] options = new Object[] {yesClose, yesOpen, cancel};
46.           final JOptionPane pane = new JOptionPane(messageString, JOptionPane.PLAIN_MESSAGE,
47.               JOptionPane.YES_NO_CANCEL_OPTION, null, options, yesClose);
48.           final JDialog window = pane.createDialog(null, "Run old jar to open old Save Game?");
49.           window.setVisible(true);
50.           final Object buttonPressed = pane.getValue();
51.           if (buttonPressed == null || buttonPressed.equals(cancel)) {
52.             return null;
53.           }
54.           final boolean closeCurrentInstance = buttonPressed.equals(yesClose);
55.           GameRunner.startGame(savegamePath, newClassPath);
56.           if (closeCurrentInstance) {
57.             ThreadUtil.sleep(1000);
58.             System.exit(0);
59.           }
60.         } catch (final IOException e) {
61.           if (ClientFileSystemHelper.areWeOldExtraJar()) {
62.             throw new IOException("<html>Please run the default TripleA and try to open this game again. "
63.                 + "<br>This TripleA engine is old and kept only for backwards compatibility and can only open "
64.                 + "savegames created by engines with these first 3 version digits: "
65.                 + ClientContext.engineVersion().toStringFull("_", true) + "</html>");
66.           } else {
67.             throw new IOException(error);
68.           }
69.         }
70.         return null;
71.       } else if (!headless && readVersion.isGreaterThan(ClientContext.engineVersion(), false)) {
72.         // we can still load it because first 3 numbers of the version are the same, however this save was made by a
73.         // newer engine, so prompt
74.         // the user to upgrade
75.         final String messageString =
76.             "<html>Your TripleA engine is OUT OF DATE.  This save was made by a newer version of TripleA."
77.                 + "<br>However, because the first 3 version numbers are the same as your current version, we can "
78.                 + "still open the savegame."
79.                 + "<br><br>This TripleA engine is version "
80.                 + ClientContext.engineVersion().toStringFull("_")
81.                 + " and you are trying to open a savegame made with version " + readVersion.toStringFull("_")
82.                 + "<br><br>To download the latest version of TripleA, Please visit "
83.                 + UrlConstants.LATEST_GAME_DOWNLOAD_WEBSITE

20.       rs.close();
21.       ps.close();
22.     } catch (final SQLException sqle) {
23.       throw new IllegalStateException("Error for testing banned username existence:" + username, sqle);
24.     } finally {
25.       DbUtil.closeConnection(con);
26.     }
27.     if (expired) {
28.       removeBannedUsername(username);
29.       return Tuple.of(false, banTill);
30.     }
31.     return Tuple.of(found, banTill);
32.   }

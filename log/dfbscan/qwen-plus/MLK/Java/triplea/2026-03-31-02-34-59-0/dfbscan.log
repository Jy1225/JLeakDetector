1. private static GameData getGameDataFromXML(final URI uri) {
2.     if (uri == null) {
3.       return null;
4.     }
5.     final AtomicReference<String> gameName = new AtomicReference<>();
6. 
7.     final Optional<InputStream> inputStream = UrlStreams.openStream(uri);
8.     if (inputStream.isPresent()) {
9.       try (InputStream input = inputStream.get()) {
10.         return new GameParser(uri.toString()).parse(input, gameName, false);
11.       } catch (final Exception e) {
12.         ClientLogger.logError("Exception while parsing: " + uri.toString() + " : "
13.             + (gameName.get() != null ? gameName.get() + " : " : ""), e);
14.       }
15.     }
16.     return null;
17.   }

1. private void removeBannedUsername(final String username) {
2.     logger.fine("Removing banned username:" + username);
3.     final Connection con = Database.getDerbyConnection();
4.     try {
5.       final PreparedStatement ps = con.prepareStatement("delete from banned_usernames where username = ?");
6.       ps.setString(1, username);
7.       ps.execute();
8.       ps.close();
9.       con.commit();
10.     } catch (final SQLException sqle) {
11.       throw new IllegalStateException("Error deleting banned username:" + username, sqle);
12.     } finally {
13.       DbUtil.closeConnection(con);
14.     }
15.   }
```

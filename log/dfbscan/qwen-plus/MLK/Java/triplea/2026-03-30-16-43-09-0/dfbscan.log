1. public Tuple<Boolean, Timestamp> isUsernameBanned(final String username) {
2.     boolean found = false;
3.     boolean expired = false;
4.     Timestamp banTill = null;
5.     final String sql = "select username, ban_till from banned_usernames where username = ?";
6.     final Connection con = Database.getDerbyConnection();
7.     try {
8.       final PreparedStatement ps = con.prepareStatement(sql);
9.       ps.setString(1, username);
10.       final ResultSet rs = ps.executeQuery();
11.       found = rs.next();
12.       // If the ban has expired, allow the username
13.       if (found) {
14.         banTill = rs.getTimestamp(2);
15.         if (banTill != null && banTill.getTime() < System.currentTimeMillis()) {
16.           logger.fine("Ban expired for:" + username);
17.           expired = true;
18.         }
19.       }
20.       rs.close();
21.       ps.close();
22.     } catch (final SQLException sqle) {
23.       throw new IllegalStateException("Error for testing banned username existence:" + username, sqle);
24.     } finally {
25.       DbUtil.closeConnection(con);
26.     }
27.     if (expired) {
28.       removeBannedUsername(username);
29.       return Tuple.of(false, banTill);
30.     }
31.     return Tuple.of(found, banTill);
32.   }
```

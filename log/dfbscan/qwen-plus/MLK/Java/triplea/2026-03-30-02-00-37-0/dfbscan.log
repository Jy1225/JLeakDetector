28.     graphics2D.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BILINEAR);
29.     graphics2D.drawImage(baseImg, 0, 0, thumbWidth, thumbHeight, null);
30.     // save thumbnail image to OUTFILE
31.     final File file = new File(new File(mapFile.getPath()).getParent() + File.separatorChar + "smallMap.jpeg");
32.     final FileImageOutputStream out = new FileImageOutputStream(file);

1. private void createAndSaveStats(final boolean showPhaseStats) {
2.     final ExtendedStats statPanel = new ExtendedStats(gameData, iuiContext);
3.     final JFileChooser chooser = new JFileChooser();
4.     chooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
5.     final File rootDir = new File(System.getProperties().getProperty("user.dir"));
6.     int currentRound = 0;
7.     try {
8.       gameData.acquireReadLock();
9.       currentRound = gameData.getSequence().getRound();
10.     } finally {
11.       gameData.releaseReadLock();
12.     }
13.     String defaultFileName =
14.         "stats_" + dateTimeFormatter.format(LocalDateTime.now()) + "_" + gameData.getGameName() + "_round_"
15.             + currentRound + (showPhaseStats ? "_full" : "_short");
16.     defaultFileName = IllegalCharacterRemover.removeIllegalCharacter(defaultFileName);
17.     defaultFileName = defaultFileName + ".csv";
18.     chooser.setSelectedFile(new File(rootDir, defaultFileName));
19.     if (chooser.showSaveDialog(frame) != JOptionPane.OK_OPTION) {
20.       return;
21.     }
22.     final StringBuilder text = new StringBuilder(1000);
23.     final GameData clone;
24.     try {
25.       gameData.acquireReadLock();
26.       clone = GameDataUtils.cloneGameData(gameData);
27.       final IStat[] stats = statPanel.getStats();
28.       // extended stats covers stuff that doesn't show up in the game stats menu bar, like custom resources or tech
29.       // tokens or # techs, etc.
30.       final IStat[] statsExtended = statPanel.getStatsExtended(gameData);
31.       final String[] alliances = statPanel.getAlliances().toArray(new String[statPanel.getAlliances().size()]);
32.       final PlayerID[] players = statPanel.getPlayers().toArray(new PlayerID[statPanel.getPlayers().size()]);
33.       // its important here to translate the player objects into our game data
34.       // the players for the stat panel are only relevant with respect to
35.       // the game data they belong to
36.       for (int i = 0; i < players.length; i++) {
37.         players[i] = clone.getPlayerList().getPlayerID(players[i].getName());
38.       }
39.       text.append(defaultFileName + ",");
40.       text.append("\n");
41.       text.append("TripleA Engine Version: ,");
42.       text.append(ClientContext.engineVersion() + ",");
43.       text.append("\n");
44.       text.append("Game Name: ,");
45.       text.append(gameData.getGameName() + ",");
46.       text.append("\n");
47.       text.append("Game Version: ,");
48.       text.append(gameData.getGameVersion() + ",");
49.       text.append("\n");
50.       text.append("\n");
51.       text.append("Current Round: ,");
52.       text.append(currentRound + ",");
53.       text.append("\n");
54.       text.append("Number of Players: ,");
55.       text.append(statPanel.getPlayers().size() + ",");
56.       text.append("\n");
57.       text.append("Number of Alliances: ,");
58.       text.append(statPanel.getAlliances().size() + ",");
59.       text.append("\n");
60.       text.append("\n");
61.       text.append("Turn Order: ,");
62.       text.append("\n");
63.       final List<PlayerID> playerOrderList = new ArrayList<>();
64.       playerOrderList.addAll(gameData.getPlayerList().getPlayers());
65.       Collections.sort(playerOrderList, new PlayerOrderComparator(gameData));
66.       final Set<PlayerID> playerOrderSetNoDuplicates = new LinkedHashSet<>(playerOrderList);
67.       final Iterator<PlayerID> playerOrderIterator = playerOrderSetNoDuplicates.iterator();
68.       while (playerOrderIterator.hasNext()) {
69.         final PlayerID currentPlayerId = playerOrderIterator.next();
70.         text.append(currentPlayerId.getName()).append(",");
71.         final Iterator<String> allianceName =
72.             gameData.getAllianceTracker().getAlliancesPlayerIsIn(currentPlayerId).iterator();
73.         while (allianceName.hasNext()) {
74.           text.append(allianceName.next()).append(",");
75.         }
76.         text.append("\n");
77.       }
78.       text.append("\n");
79.       text.append("Winners: ,");
80.       final EndRoundDelegate delegateEndRound = (EndRoundDelegate) gameData.getDelegateList().getDelegate("endRound");
81.       if (delegateEndRound != null && delegateEndRound.getWinners() != null) {
82.         for (final PlayerID p : delegateEndRound.getWinners()) {
83.           text.append(p.getName()).append(",");
84.         }
85.       } else {
86.         text.append("none yet; game not over,");
87.       }
88.       text.append("\n");
89.       text.append("\n");
90.       text.append("Resource Chart: ,");
91.       text.append("\n");
92.       final Iterator<Resource> resourceIterator = gameData.getResourceList().getResources().iterator();

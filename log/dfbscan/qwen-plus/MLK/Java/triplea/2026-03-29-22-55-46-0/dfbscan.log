1. private void startStep(final boolean stepIsRestoredFromSavedGame) {
2.     // dont save if we just loaded
3.     final DefaultDelegateBridge bridge = new DefaultDelegateBridge(m_data, this,
4.         new DelegateHistoryWriter(m_channelMessenger), m_randomStats, m_delegateExecutionManager);
5.     if (m_delegateRandomSource == null) {
6.       m_delegateRandomSource = (IRandomSource) m_delegateExecutionManager.createOutboundImplementation(m_randomSource,
7.           new Class<?>[] {IRandomSource.class});
8.     }
9.     bridge.setRandomSource(m_delegateRandomSource);
10.     // do any initialization of game data for all players here (not based on a delegate, and should not be)
11.     // we cannot do this the very first run through, because there are no history nodes yet. We should do after first
12.     // node is created.
13.     if (m_needToInitialize) {
14.       addPlayerTypesToGameData(m_gamePlayers.values(), m_playerManager, bridge);
15.     }
16.     notifyGameStepChanged(stepIsRestoredFromSavedGame);
17.     m_delegateExecutionManager.enterDelegateExecution();
18.     try {
19.       final IDelegate delegate = getCurrentStep().getDelegate();
20.       delegate.setDelegateBridgeAndPlayer(bridge);
21.       delegate.start();
22.     } finally {
23.       m_delegateExecutionManager.leaveDelegateExecution();
24.     }
25.   }

1. private static void saveGameInSerializationFormat(
2.       final OutputStream sink,
3.       final GameData data,
4.       final boolean saveDelegateInfo)
5.       throws IOException {
6.     // write internally first in case of error
7.     final ByteArrayOutputStream bytes = new ByteArrayOutputStream(25000);
8.     final ObjectOutputStream outStream = new ObjectOutputStream(bytes);
9.     outStream.writeObject(ClientContext.engineVersion());
10.     data.acquireReadLock();
11.     try {
12.       outStream.writeObject(data);
13.       if (saveDelegateInfo) {
14.         writeDelegates(data, outStream);
15.       } else {
16.         outStream.writeObject(DELEGATE_LIST_END);
17.       }
18.     } finally {
19.       data.releaseReadLock();
20.     }
21.     try (final GZIPOutputStream zippedOut = new GZIPOutputStream(sink)) {
22.       // now write to file
23.       zippedOut.write(bytes.toByteArray());
24.     }
25.   }
```

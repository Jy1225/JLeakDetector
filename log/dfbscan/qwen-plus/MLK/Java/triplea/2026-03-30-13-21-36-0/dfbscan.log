1. public void addObserver(final IObserverWaitingToJoin blockingObserver,
2.       final IObserverWaitingToJoin nonBlockingObserver, final INode newNode) {
3.     try {
4.       if (!m_delegateExecutionManager.blockDelegateExecution(2000)) {
5.         nonBlockingObserver.cannotJoinGame("Could not block delegate execution");
6.         return;
7.       }
8.     } catch (final InterruptedException e) {
9.       nonBlockingObserver.cannotJoinGame(e.getMessage());
10.       return;
11.     }
12.     try {
13.       final CountDownLatch waitOnObserver = new CountDownLatch(1);
14.       final ByteArrayOutputStream sink = new ByteArrayOutputStream(1000);
15.       saveGame(sink);
16.       (new Thread(() -> {
17.         try {
18.           blockingObserver.joinGame(sink.toByteArray(), m_playerManager.getPlayerMapping());
19.           waitOnObserver.countDown();
20.         } catch (final ConnectionLostException cle) {
21.           System.out.println("Connection lost to observer while joining: " + newNode.getName());
22.         } catch (final Exception e) {
23.           ClientLogger.logQuietly(e);
24.         }
25.       }, "Waiting on observer to finish joining: " + newNode.getName())).start();
26.       try {
27.         if (!waitOnObserver.await(ClientSetting.SERVER_OBSERVER_JOIN_WAIT_TIME.intValue(), TimeUnit.SECONDS)) {
28.           nonBlockingObserver.cannotJoinGame("Taking too long to join.");
29.         }
30.       } catch (final InterruptedException e) {
31.         ClientLogger.logQuietly(e);
32.         nonBlockingObserver.cannotJoinGame(e.getMessage());
33.       }
34.     } catch (final Exception e) {
35.       ClientLogger.logQuietly(e);
36.       nonBlockingObserver.cannotJoinGame(e.getMessage());
37.     } finally {
38.       m_delegateExecutionManager.resumeDelegateExecution();
39.     }
40.   }

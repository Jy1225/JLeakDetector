22.         } catch (final Exception e) {
23.           ClientLogger.logQuietly(e);
24.         }
25.       }, "Waiting on observer to finish joining: " + newNode.getName())).start();
26.       try {
27.         if (!waitOnObserver.await(ClientSetting.SERVER_OBSERVER_JOIN_WAIT_TIME.intValue(), TimeUnit.SECONDS)) {
28.           nonBlockingObserver.cannotJoinGame("Taking too long to join.");

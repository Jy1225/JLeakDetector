1. private Thread createDownloadThread() {
2.     return new Thread(() -> {
3.       if (state == DownloadState.CANCELLED) {
4.         return;
5.       }
6. 
7.       final File tempFile = newTempFile();
8.       final FileSizeWatcher watcher = new FileSizeWatcher(
9.           tempFile,
10.           bytesReceived -> downloadListener.downloadUpdated(download, bytesReceived));
11.       try {
12.         DownloadUtils.downloadToFile(download.getUrl(), tempFile);
13.       } catch (final IOException e) {
14.         ClientLogger.logError("Failed to download: " + download.getUrl(), e);
15.         return;
16.       } finally {
17.         watcher.stop();
18.       }
19. 
20.       if (state == DownloadState.CANCELLED) {
21.         return;
22.       }
23. 
24.       state = DownloadState.DONE;
25. 
26.       try {
27.         Files.move(tempFile, download.getInstallLocation());
28.       } catch (final IOException e) {
29.         ClientLogger.logError(
30.             String.format("Failed to move downloaded file (%s) to: %s", tempFile, download.getInstallLocation()),
31.             e);
32.         return;
33.       }
34. 
35.       final DownloadFileProperties props = new DownloadFileProperties();
36.       props.setFrom(download);
37.       DownloadFileProperties.saveForZip(download.getInstallLocation(), props);
38. 
39.       downloadListener.downloadStopped(download);
40.     });
41.   }

2.   public void sendEmail(final String subject, final String htmlMessage, final File saveGame, final String saveGameName)
3.       throws IOException {
4.     // this is the last step and we create the email to send
5.     if (m_toAddress == null) {
6.       throw new IOException("Could not send email, no To address configured");
7.     }

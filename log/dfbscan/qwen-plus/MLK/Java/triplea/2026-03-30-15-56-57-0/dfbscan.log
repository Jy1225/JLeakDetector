11.     try {
12.       final PreparedStatement ps = con.prepareStatement("insert into muted_macs (mac, mute_till) values (?, ?)");
13.       ps.setString(1, mac);
14.       ps.setTimestamp(2, muteTillTs);
15.       ps.execute();
16.       ps.close();
17.       con.commit();
18.     } catch (final SQLException sqle) {
19.       if (sqle.getErrorCode() == 30000) {
20.         // this is ok
21.         // the mac is muted as expected
22.         logger.info("Tried to create duplicate muted mac:" + mac + " error:" + sqle.getMessage());
23.         return;
24.       }
25.       throw new IllegalStateException("Error inserting muted mac:" + mac, sqle);
26.     } finally {
27.       DbUtil.closeConnection(con);

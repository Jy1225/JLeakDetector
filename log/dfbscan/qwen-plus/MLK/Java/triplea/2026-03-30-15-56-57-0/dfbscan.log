5.     final GameData clonedGameData;
6.     data.acquireReadLock();
7.     try {
8.       // we want to use a clone of the data, so we can make changes to it
9.       // as we walk up and down the history
10.       clonedGameData = GameDataUtils.cloneGameData(data);
11.       if (clonedGameData == null) {
12.         return;
13.       }
14.       data.removeDataChangeListener(dataChangeListener);
15.       clonedGameData.testLocksOnRead();
16.       if (historySyncher != null) {
17.         throw new IllegalStateException("Two history synchers?");
18.       }
19.       historySyncher = new HistorySynchronizer(clonedGameData, game);
20.       clonedGameData.addDataChangeListener(dataChangeListener);
21.     } finally {
22.       data.releaseReadLock();
23.     }
24.     statsPanel.setGameData(clonedGameData);
25.     economyPanel.setGameData(clonedGameData);
26.     if (objectivePanel != null && !objectivePanel.isEmpty()) {
27.       objectivePanel.setGameData(clonedGameData);
28.     }
29.     details.setGameData(clonedGameData);

66.         } catch (final SQLException e) {
67.           // ignore close errors
68.         }
69.         logger.log(Level.SEVERE, sqle.getMessage(), sqle);
70.         throw new IllegalStateException("Could not create tables");
71.       }
72.     }
73.   }

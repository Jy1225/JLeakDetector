102.                 JOptionPane.ERROR_MESSAGE);
103.           }
104.         };
105.         SwingUtilities.invokeLater(runnable);
106.       };
107.       // start a new thread for posting the summary.
108.       new Thread(t).start();
109.     }
110.   }

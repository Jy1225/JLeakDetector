10.       while (current != null) {
11.         if (current.trim().length() != 0) {
12.           readSingle(current, mapping);
13.         }
14.         current = reader.readLine();
15.       }
16.     } finally {
17.       stream.close();
18.     }
19.     return mapping;
20.   }

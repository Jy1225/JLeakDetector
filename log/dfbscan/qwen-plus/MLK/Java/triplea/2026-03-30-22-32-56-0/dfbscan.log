23.       final Source xmlSource = new StreamSource(gameXmlStream, system);
24.       resultBuf = new ByteArrayOutputStream();
25.       trans.transform(xmlSource, new StreamResult(resultBuf));
26.     }
27.     gameXmlFile.renameTo(new File(gameXmlFile.getAbsolutePath() + ".backup"));
28.     final FileOutputStream outStream = new FileOutputStream(gameXmlFile);
29.     outStream.write(resultBuf.toByteArray());
30.     outStream.close();
31.     System.out.println("Successfully updated:" + gameXmlFile);

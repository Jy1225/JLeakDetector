32.           game.addDisplay(display);
33.           soundChannel = new DefaultSoundChannel(localPlayers);
34.           game.addSoundChannel(soundChannel);
35.           frame.setSize(700, 400);
36.           frame.setVisible(true);
37.           ClipPlayer.play(SoundPath.CLIP_GAME_START);
38.           connectPlayers(players, frame);
39.           frame.setExtendedState(Frame.MAXIMIZED_BOTH);
40.           frame.toFront();

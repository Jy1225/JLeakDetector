1. public static void main(final String[] args) throws Exception {
2.     handleCommandLineArgs(args);
3.     JOptionPane.showMessageDialog(null,
4.         new JLabel("<html>" + "This is the ImageShrinker, it will create a smallMap.jpeg file for you. "
5.             + "<br>Put in your base map or relief map, and it will spit out a small scaled copy of it."
6.             + "<br>Please note that the quality of the image will be worse than if you use a real painting program."
7.             + "<br>So we suggest you instead shrink the image with paint.net or photoshop or gimp, etc, then clean it "
8.             + "up before saving."
9.             + "</html>"));
10.     final File mapFile = new FileOpen("Select The Large Image", mapFolderLocation, ".gif", ".png").getFile();
11.     if (mapFile == null || !mapFile.exists()) {
12.       throw new IllegalStateException(mapFile + "File does not exist");
13.     }
14.     if (mapFolderLocation == null) {
15.       mapFolderLocation = mapFile.getParentFile();
16.     }
17.     final String input = JOptionPane.showInputDialog(null, "Select scale");
18.     final float scale = Float.parseFloat(input);
19.     final Image baseImg = ImageIO.read(mapFile);
20.     final int thumbWidth = (int) (baseImg.getWidth(null) * scale);
21.     final int thumbHeight = (int) (baseImg.getHeight(null) * scale);
22.     // based on code from
23.     // http://www.geocities.com/marcoschmidt.geo/java-save-jpeg-thumbnail.html
24.     // draw original image to thumbnail image object and
25.     // scale it to the new size on-the-fly
26.     final BufferedImage thumbImage = new BufferedImage(thumbWidth, thumbHeight, BufferedImage.TYPE_INT_RGB);
27.     final Graphics2D graphics2D = thumbImage.createGraphics();
28.     graphics2D.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BILINEAR);
29.     graphics2D.drawImage(baseImg, 0, 0, thumbWidth, thumbHeight, null);
30.     // save thumbnail image to OUTFILE
31.     final File file = new File(new File(mapFile.getPath()).getParent() + File.separatorChar + "smallMap.jpeg");
32.     final FileImageOutputStream out = new FileImageOutputStream(file);
33.     final ImageWriter encoder = ImageIO.getImageWritersByFormatName("JPEG").next();
34.     final JPEGImageWriteParam param = new JPEGImageWriteParam(null);
35.     param.setCompressionMode(ImageWriteParam.MODE_EXPLICIT);
36.     param.setCompressionQuality((float) 1.0);
37.     encoder.setOutput(out);
38.     encoder.write(null, new IIOImage(thumbImage, null, null), param);
39.     out.close();
40.     System.out.println("Image successfully written to " + file.getPath());
41.     System.exit(0);
42.   }

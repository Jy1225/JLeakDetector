1. public void addObserver(final IObserverWaitingToJoin blockingObserver,
2.       final IObserverWaitingToJoin nonBlockingObserver, final INode newNode) {
3.     try {
4.       if (!m_delegateExecutionManager.blockDelegateExecution(2000)) {
5.         nonBlockingObserver.cannotJoinGame("Could not block delegate execution");
6.         return;
7.       }
8.     } catch (final InterruptedException e) {
9.       nonBlockingObserver.cannotJoinGame(e.getMessage());
10.       return;
11.     }
12.     try {

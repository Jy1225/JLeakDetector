1. public static Map<String, List<Point>> readOneToMany(final InputStream stream) {
2.     if (stream == null) {
3.       return Collections.emptyMap();
4.     }
5. 
6.     final HashMap<String, List<Point>> mapping = new HashMap<>();
7.     try (InputStreamReader inputStreamReader = new InputStreamReader(stream);
8.         LineNumberReader reader = new LineNumberReader(inputStreamReader)) {
9.       String current = reader.readLine();
10.       while (current != null) {
11.         if (current.trim().length() != 0) {
12.           readMultiple(current, mapping);
13.         }
14.         current = reader.readLine();
15.       }
16.     } catch (final IOException ioe) {
17.       ClientLogger.logError(ioe);
18.       System.exit(0);
19.     } finally {
20.       try {
21.         stream.close();
22.       } catch (final IOException e) {
23.         ClientLogger.logError(e);
24.       }
25.     }
26.     return mapping;
27.   }

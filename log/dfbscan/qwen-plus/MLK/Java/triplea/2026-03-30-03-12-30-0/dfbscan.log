1. public void acquireLock(final Lock lock) {
2.     // we already have the lock, increase the count
3.     if (isLockHeld(lock)) {
4.       final int current = locksHeld.get().get(lock);
5.       locksHeld.get().put(lock, current + 1);
6.     } else { // we don't have it
7.       synchronized (mutex) {
8.         // all the locks currently held must be acquired before a lock
9.         if (!locksHeldWhenAcquired.containsKey(lock)) {
10.           locksHeldWhenAcquired.put(lock, new HashSet<>());
11.         }
12.         for (final Lock l : locksHeld.get().keySet()) {
13.           locksHeldWhenAcquired.get(lock).add(new WeakLockRef(l));
14.         }
15.         // we are lock a, check to
16.         // see if any lock we hold (b)
17.         // has ever been acquired before a
18.         for (final Lock l : locksHeld.get().keySet()) {
19.           final Set<WeakLockRef> held = locksHeldWhenAcquired.get(l);
20.           // clear out of date locks
21.           final Iterator<WeakLockRef> iter = held.iterator();
22.           while (iter.hasNext()) {
23.             if (iter.next().get() == null) {
24.               iter.remove();
25.             }
26.           }
27.           if (held.contains(new WeakLockRef(lock))) {
28.             errorReporterRef.get().reportError(lock, l);
29.           }
30.         }
31.       }
32.       locksHeld.get().put(lock, 1);
33.     }
34. 
35.     lock.lock();
36.   }

1. public static Map<String, List<Polygon>> readOneToManyPolygons(final InputStream stream) {
2.     final HashMap<String, List<Polygon>> mapping = new HashMap<>();
3.     try (InputStreamReader inputStreamReader = new InputStreamReader(stream);
4.         LineNumberReader reader = new LineNumberReader(inputStreamReader)) {
5.       String current = reader.readLine();
6.       while (current != null) {
7.         if (current.trim().length() != 0) {
8.           readMultiplePolygons(current, mapping);
9.         }
10.         current = reader.readLine();
11.       }
12.     } catch (final IOException e) {
13.       ClientLogger.logQuietly(e);
14.       System.exit(0);
15.     } finally {
16.       try {
17.         if (stream != null) {
18.           stream.close();
19.         }
20.       } catch (final IOException e) {
21.         ClientLogger.logError(e);
22.       }
23.     }
24.     return mapping;
25.   }

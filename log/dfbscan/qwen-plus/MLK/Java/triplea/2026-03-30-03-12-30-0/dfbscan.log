1. public void addBannedMac(final String mac, final Instant banTill) {
2.     if (isMacBanned(mac).getFirst()) {
3.       removeBannedMac(mac);
4.     }
5.     Timestamp banTillTs = null;
6.     if (banTill != null) {
7.       banTillTs = new Timestamp(banTill.toEpochMilli());
8.     }
9.     logger.fine("Banning mac:" + mac);
10.     final Connection con = Database.getDerbyConnection();
11.     try {
12.       final PreparedStatement ps = con.prepareStatement("insert into banned_macs (mac, ban_till) values (?, ?)");
13.       ps.setString(1, mac);
14.       ps.setTimestamp(2, banTillTs);
15.       ps.execute();
16.       ps.close();
17.       con.commit();
18.     } catch (final SQLException sqle) {
19.       if (sqle.getErrorCode() == 30000) {
20.         // this is ok
21.         // the mac is banned as expected
22.         logger.info("Tried to create duplicate banned mac:" + mac + " error:" + sqle.getMessage());
23.         return;
24.       }
25.       throw new IllegalStateException("Error inserting banned mac:" + mac, sqle);
26.     } finally {
27.       DbUtil.closeConnection(con);
28.     }
29.   }

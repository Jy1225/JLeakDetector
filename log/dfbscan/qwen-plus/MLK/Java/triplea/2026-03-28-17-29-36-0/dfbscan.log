1. public void load(final File file, final Component ui) {
2.     if (!file.exists()) {
3.       if (ui == null) {
4.         System.out.println("Could not find file:" + file);
5.       } else {
6.         error("Could not find file:" + file, ui);
7.       }
8.       return;
9.     }
10.     if (file.isDirectory()) {
11.       if (ui == null) {
12.         System.out.println("Cannot load a directory:" + file);
13.       } else {
14.         error("Cannot load a directory:" + file, ui);
15.       }
16.       return;
17.     }
18.     final GameData newData;
19.     final AtomicReference<String> gameName = new AtomicReference<>();
20.     try {
21.       // if the file name is xml, load it as a new game
22.       if (file.getName().toLowerCase().endsWith("xml")) {
23.         try (FileInputStream fis = new FileInputStream(file)) {
24.           newData = new GameParser(file.getAbsolutePath()).parse(fis, gameName, false);
25.         }
26.       } else {
27.         // try to load it as a saved game whatever the extension
28.         newData = GameDataManager.loadGame(file);
29.       }
30.       if (newData != null) {
31.         m_fileName = file.getName();
32.         setGameData(newData);
33.       }
34.     } catch (final EngineVersionException e) {
35.       System.out.println(e.getMessage());
36.     } catch (final Exception e) {
37.       String message = e.getMessage();
38.       if (message == null && e.getStackTrace() != null) {
39.         message = e.getClass().getName() + "  at  " + e.getStackTrace()[0].toString();
40.       }
41.       message = "Exception while parsing: " + file.getName() + " : "
42.           + (gameName.get() != null ? gameName.get() + " : " : "") + message;
43.       ClientLogger.logQuietly(e);
44.       if (ui != null) {
45.         error(message + "\r\nPlease see console for full error log!", ui);
46.       }
47.     }
48.   }
```

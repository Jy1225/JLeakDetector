1. private void createAndSaveStats(final boolean showPhaseStats) {
2.     final ExtendedStats statPanel = new ExtendedStats(gameData, iuiContext);
3.     final JFileChooser chooser = new JFileChooser();
4.     chooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
5.     final File rootDir = new File(System.getProperties().getProperty("user.dir"));
6.     int currentRound = 0;
7.     try {
8.       gameData.acquireReadLock();
9.       currentRound = gameData.getSequence().getRound();
10.     } finally {
11.       gameData.releaseReadLock();
12.     }
13.     String defaultFileName =
14.         "stats_" + dateTimeFormatter.format(LocalDateTime.now()) + "_" + gameData.getGameName() + "_round_"
15.             + currentRound + (showPhaseStats ? "_full" : "_short");
16.     defaultFileName = IllegalCharacterRemover.removeIllegalCharacter(defaultFileName);
17.     defaultFileName = defaultFileName + ".csv";
18.     chooser.setSelectedFile(new File(rootDir, defaultFileName));
19.     if (chooser.showSaveDialog(frame) != JOptionPane.OK_OPTION) {
20.       return;
21.     }
22.     final StringBuilder text = new StringBuilder(1000);
23.     final GameData clone;
24.     try {
25.       gameData.acquireReadLock();
26.       clone = GameDataUtils.cloneGameData(gameData);
27.       final IStat[] stats = statPanel.getStats();
28.       // extended stats covers stuff that doesn't show up in the game stats menu bar, like custom resources or tech
29.       // tokens or # techs, etc.
30.       final IStat[] statsExtended = statPanel.getStatsExtended(gameData);
31.       final String[] alliances = statPanel.getAlliances().toArray(new String[statPanel.getAlliances().size()]);
32.       final PlayerID[] players = statPanel.getPlayers().toArray(new PlayerID[statPanel.getPlayers().size()]);
33.       // its important here to translate the player objects into our game data

1. public void addBadWord(final String word) {
2.     logger.fine("Adding bad word word:" + word);
3.     final Connection con = Database.getDerbyConnection();
4.     try {
5.       final PreparedStatement ps = con.prepareStatement("insert into bad_words (word) values (?)");
6.       ps.setString(1, word);
7.       ps.execute();
8.       ps.close();
9.       con.commit();
10.     } catch (final SQLException sqle) {
11.       if (sqle.getErrorCode() == 30000) {
12.         // this is ok
13.         // the word is bad as expected
14.         logger.info("Tried to create duplicate banned word:" + word + " error:" + sqle.getMessage());
15.         return;
16.       }
17.       throw new IllegalStateException("Error inserting banned word:" + word, sqle);
18.     } finally {
19.       DbUtil.closeConnection(con);
20.     }
21.   }

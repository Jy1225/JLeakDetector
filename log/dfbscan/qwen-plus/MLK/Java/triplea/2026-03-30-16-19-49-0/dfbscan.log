1. private static boolean addToAvailableGames(final URI uri, final Map<String, URI> availableGames,
2.       final Set<String> mapNamePropertyList) {
3.     if (uri == null) {
4.       return false;
5.     }
6.     final AtomicReference<String> gameName = new AtomicReference<>();
7. 

22.               final GameData datacopy = GameDataUtils.cloneGameData(data, true);
23.               datacopy.getHistory().gotoNode(historyPanel.getCurrentPopupNode());
24.               datacopy.getHistory().removeAllHistoryAfterNode(historyPanel.getCurrentPopupNode());
25.               // TODO: the saved current delegate is still the current delegate,
26.               // rather than the delegate at that history popup node
27.               // TODO: it still shows the current round number, rather than the round at the history popup node
28.               // TODO: this could be solved easily if rounds/steps were changes,
29.               // but that could greatly increase the file size :(
30.               // TODO: this also does not undo the runcount of each delegate step
31.               @SuppressWarnings("unchecked")
32.               final Enumeration<TreeNode> enumeration =
33.                   ((DefaultMutableTreeNode) datacopy.getHistory().getRoot()).preorderEnumeration();
34.               enumeration.nextElement();
35.               int round = 0;
36.               String stepDisplayName = datacopy.getSequence().getStep(0).getDisplayName();
37.               PlayerID currentPlayer = datacopy.getSequence().getStep(0).getPlayerID();
38.               while (enumeration.hasMoreElements()) {
39.                 final HistoryNode node = (HistoryNode) enumeration.nextElement();
40.                 if (node instanceof Round) {
41.                   round = Math.max(0, ((Round) node).getRoundNo() - datacopy.getSequence().getRoundOffset());
42.                   currentPlayer = null;
43.                   stepDisplayName = node.getTitle();
44.                 } else if (node instanceof Step) {
45.                   currentPlayer = ((Step) node).getPlayerID();
46.                   stepDisplayName = node.getTitle();
47.                 }
48.               }
49.               datacopy.getSequence().setRoundAndStep(round, stepDisplayName, currentPlayer);

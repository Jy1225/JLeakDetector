11.       if (found) {
12.         final Timestamp muteTill = rs.getTimestamp(2);
13.         result = muteTill.getTime();
14.         if (result < System.currentTimeMillis()) {
15.           logger.fine("Mute expired for:" + mac);
16.           expired = true;
17.         }
18.       } else {
19.         result = -1;
20.       }
21.       rs.close();
22.       ps.close();
23.     } catch (final SQLException sqle) {
24.       throw new IllegalStateException("Error for testing muted mac existence:" + mac, sqle);
25.     } finally {
26.       DbUtil.closeConnection(con);
27.     }
28.     // If the mute has expired, allow the mac
29.     if (expired) {
30.       removeMutedMac(mac);
31.       // Signal as not-muted
32.       result = -1;
33.     }
34.     return result;
35.   }

1. public static Connection getDerbyConnection() {
2.     final String url = "jdbc:derby:ta_users;create=true";
3.     return getConnection(url, getDbProps());
4.   }
```

```
1. public List<String> list() {
2.     final String sql = "select word from bad_words";
3.     final Connection con = Database.getDerbyConnection();
4.     try {
5.       final PreparedStatement ps = con.prepareStatement(sql);
6.       final ResultSet rs = ps.executeQuery();
7.       final List<String> rVal = new ArrayList<>();
8.       while (rs.next()) {
9.         rVal.add(rs.getString(1));
10.       }
11.       rs.close();
12.       ps.close();
13.       return rVal;
14.     } catch (final SQLException sqle) {
15.       throw new IllegalStateException("Error reading bad words", sqle);
16.     } finally {
17.       DbUtil.closeConnection(con);
18.     }
19.   }
```

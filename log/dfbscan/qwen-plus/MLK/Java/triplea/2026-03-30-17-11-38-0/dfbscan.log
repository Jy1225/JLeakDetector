12.       final PreparedStatement ps =
13.           con.prepareStatement("insert into muted_usernames (username, mute_till) values (?, ?)");
14.       ps.setString(1, username);
15.       ps.setTimestamp(2, muteTillTs);
16.       ps.execute();
17.       ps.close();
18.       con.commit();
19.     } catch (final SQLException sqle) {
20.       if (sqle.getErrorCode() == 30000) {
21.         // this is ok
22.         // the username is muted as expected
23.         logger.info("Tried to create duplicate muted username:" + username + " error:" + sqle.getMessage());
24.         return;
25.       }
26.       throw new IllegalStateException("Error inserting muted username:" + username, sqle);
27.     } finally {
28.       DbUtil.closeConnection(con);
29.     }
30.   }

1. public String toTarget(Translator translator, Symbol symbol) {
2.         if (symbol.childAt(0).childAt(0).isType(WikiWord.symbolType)) return translator.translate(symbol.childAt(0));
3. 
4.         String linkBody = translator.translate(symbol.childAt(0));

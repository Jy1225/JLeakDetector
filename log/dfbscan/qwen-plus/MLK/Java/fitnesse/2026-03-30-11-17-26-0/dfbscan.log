1. public void process(WikiPage currentPage) {
2.     PageData data = currentPage.getData();
3.     String content = data.getContent();
4. 
5.       Symbol syntaxTree = Parser.make(
6.               new ParsingPage(new WikiSourcePage(currentPage)),
7.               content,
8.               SymbolProvider.refactoringProvider)
9.               .parse();
10.       this.currentPage = currentPage;
11.       syntaxTree.walkPreOrder(this);
12.       String newContent = new WikiTranslator(new WikiSourcePage(currentPage)).translateTree(syntaxTree);
13. 
14.     boolean pageHasChanged = !newContent.equals(content);
15.     if (pageHasChanged) {
16.       data.setContent(newContent);
17.       currentPage.commit(data);
18.     }
19.   }
```

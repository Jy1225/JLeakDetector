15.     // Set a hard limit on the amount of data that can be read:
16.     byte[] content = reader.readBytes(RESOURCE_SIZE_LIMIT);
17.     SimpleResponse response = new SimpleResponse();
18.     response.setContent(content);
19.     setContentType(classpathResource, response);
20.     lastModifiedDate = LAST_MODIFIED_FOR_RESOURCES;

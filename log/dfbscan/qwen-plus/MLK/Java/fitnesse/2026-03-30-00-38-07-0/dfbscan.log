2.     Socket socket = new Socket(hostname, hostPort);
3.     OutputStream socketOut = socket.getOutputStream();
4.     InputStream socketIn = socket.getInputStream();
5.     builder.send(socketOut);
6.     socketOut.flush();
7.     try {
8.       return new ResponseParser(socketIn);
9.     } finally {
10.       socketOut.close();
11.       socket.close();
12.     }
13.   }
```


2.       StreamReader reader, String boundary) throws IOException {
3.     String filename = headers.get("filename");
4.     String contentType = headers.get("content-type");
5.     File tempFile = File.createTempFile("FitNesse", ".uploadedFile");
6.     OutputStream output = null;
7.     try {
8.       output = new BufferedOutputStream(new FileOutputStream(tempFile));
9.       reader.copyBytesUpTo("\r\n" + boundary, output);

22.     } catch (Exception e) {
23.       throw new RuntimeException(e);
24.     } finally {
25.       try {
26.         if (zipFile != null) {
27.           zipFile.close();
28.         }
29.       } catch (IOException e) {
30.         LOG.log(Level.WARNING, "Unable to read zip file contents", e);
31.       }
32.     }
33.   }

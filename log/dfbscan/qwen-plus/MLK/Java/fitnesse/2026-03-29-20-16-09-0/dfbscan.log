1. public String toTarget(Translator translator, Symbol symbol) {
2.         if (symbol.childAt(0).childAt(0).isType(WikiWord.symbolType)) return translator.translate(symbol.childAt(0));
3. 
4.         String linkBody = translator.translate(symbol.childAt(0));
5.         String linkReferenceString = HtmlUtil.unescapeHTML(translator.translate(symbol.childAt(1)));
6.         ParsingPage parsingPage = ((HtmlTranslator)translator).getParsingPage();
7.         Symbol linkReference = Parser.make(parsingPage, linkReferenceString).parseToIgnoreFirst(Comment.symbolType);
8. 
9.         if (linkReference.childAt(0).isType(WikiWord.symbolType) || PathParser.isWikiPath(linkReference.childAt(0).getContent())) {
10.             return new WikiWordBuilder(translator.getPage(), linkReference.childAt(0).getContent(), linkBody)
11.                     .buildLink(translator.translate(linkReference.childrenAfter(0)), linkBody);
12.         }
13. 
14.         HtmlTag alias = new HtmlTag("a", linkBody);
15. 
16.         if (linkReference.childAt(0).isType(Link.symbolType)) {
17.             alias.addAttribute("href", linkReferenceString.startsWith("http://files/") ? linkReferenceString.substring(7) : linkReferenceString);
18.         } else {
19.             alias.addAttribute("href", translator.translate(linkReference));
20.         }
21. 
22.         return alias.htmlInline();
23.     }

5.         writer.putAttribute("class", symbol.getProperty("class"));
6.       }
7.       int longestRow = longestRow(symbol);
8.       int rowCount = 0;
9.       for (Symbol child : symbol.getChildren()) {
10.         rowCount++;
11.         writer.startTag("tr");
12.         if (rowCount == 1 && symbol.hasProperty("hideFirst")) {
13.           writer.putAttribute("class", "hidden");
14.         }
15.         int extraColumnSpan = longestRow - rowLength(child);
16.         int column = 1;
17.         for (Symbol grandChild : child.getChildren()) {
18.           String body = translateCellBody(translator, grandChild);
19.           writer.startTag("td");
20.           if (extraColumnSpan > 0 && column == rowLength(child))
21.             writer.putAttribute("colspan", Integer.toString(extraColumnSpan + 1));
22.           writer.putText(body);
23.           writer.endTag();
24.           column++;
25.         }
26.         writer.endTag();
27.       }
28.       writer.endTag();
29.       return writer.toHtml();
30.     }

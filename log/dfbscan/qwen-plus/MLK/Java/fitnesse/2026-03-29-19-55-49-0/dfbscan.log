9.             next = parser.moveNext(1);
10.             if (!next.isType(SymbolType.Whitespace)) return Symbol.nothing;
11.             next = parser.moveNext(1);
12.         }
13.         if (!next.isType(SymbolType.Text) && !next.isType(WikiWord.symbolType)) return Symbol.nothing;
14. 
15.         current.add(option).add(next);
16. 
17.         Maybe<SourcePage> includedPage = parser.getPage().getNamedPage().findIncludedPage(next.getContent());
18.         if (includedPage.isNothing()) {
19.           current.add("").add(new Symbol(SymbolType.Style, "error").add(includedPage.because()));
20.         }
21.         else if (includeHelpOption.equals(option)) {
22.         	String helpText = includedPage.getValue().getProperty(PageData.PropertyHELP);	
23.         	current.add("").add(Parser.make(
24.         			parser.getPage(),helpText).parse());
25.         } else {
26.             current.childAt(1).putProperty(WikiWord.WITH_EDIT, "true");
27.             ParsingPage included = option.equals("-setup") || option.equals("-teardown")
28.                     ? parser.getPage()
29.                     : parser.getPage().copyForNamedPage(includedPage.getValue());
30.             current.add("").add(Parser.make(
31.                             included,

25. 
26.             if(rowCount == 1 && column == 1){
27.                 String tableName = body;
28. 
29.                 // If is slim table class declaration then get fixture info for table coloring scheme.
30.                 SlimTableFactory sf = new SlimTableFactory();
31.                 Class<? extends SlimTable> slimTableClazz = sf.getTableType(tableName);
32.                 if(slimTableClazz != null){
33.                     colorTable = true;
34.                     if(secondRowTitleClasses.contains(slimTableClazz.getName())){
35.                         isSecondRowTitle = true;
36.                     }else if(slimTableClazz.getName().equals("fitnesse.testsystems.slim.tables.ImportTable")){
37.                         isImportFixture = true;
38.                     }else if(slimTableClazz.getName().equals("fitnesse.testsystems.slim.tables.ScriptTable") ||
39.                             slimTableClazz.getName().equals("fitnesse.testsystems.slim.tables.ScenarioTable")){
40.                         isFirstColumnTitle = true;
41.                     }
42.                 }
43. 
44.                 // Unmarked decision tables aren't found by getTableType().  Color table if first row is valid class.
45.                 if(!colorTable) {
46.                     List<String> potentialClasses = new FixtureName(tableName)
47.                         .getPotentialFixtureClassNames(FixtureLoader.instance().fixturePathElements);
48.                     for(String potentialClass: potentialClasses){
49.                         Class<?> fixtureClazz;
50.                         try{
51.                             fixtureClazz = Class.forName(potentialClass);
52.                             if(fixtureClazz == null){ continue; }
53.                             colorTable = true;
54.                             isSecondRowTitle = true;
55.                         }catch(ClassNotFoundException cnfe){ }
56.                         catch(NoClassDefFoundError ncdfe){ }
57.                     }
58.                 }
59.             }
60. 
61.             // Use color scheme attributes to color table rows.
62.             if(colorTable && column == 1){
63.                 if(isImportFixture){ FixtureLoader.instance().addPackageToPath(body); }
64. 
65.                 if(rowCount == 1){
66.                     writer.putAttribute("class", "slimRowTitle");
67.                 }else if(isSecondRowTitle && rowCount == 2){
68.                     writer.putAttribute("class", "slimRowTitle");
69.                 }else if(isFirstColumnTitle){
70.                     byte[] bodyBytes = body.getBytes();
71.                     int sum = 0;
72.                     for(byte b: bodyBytes){
73.                         sum = sum + (int) b;
74.                     }
75.                     writer.putAttribute("class", "slimRowColor" + (sum % 10));
76.                 }else if(!isCommentFixture){
77.                     writer.putAttribute("class", "slimRowColor" + (rowCount % 2));
78.                 }
79.             }
80.             writer.startTag("td");
81.             if (extraColumnSpan > 0 && column == ((Table)baseSymbolType).rowLength(child))
82.               writer.putAttribute("colspan", Integer.toString(extraColumnSpan + 1));
83.             writer.putText(body);
84.             writer.endTag();
85.             column++;
86.           }
87.           writer.endTag();
88.         }
89.         writer.endTag();
90.         return writer.toHtml();
91.     }

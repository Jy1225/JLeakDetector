1. @Override
2.   public String format(LogRecord logRecord) {
3.     StringBuilder builder = new StringBuilder(128);
4.     Throwable thrown = logRecord.getThrown();
5. 
6.     if (atLeastWarningLevel(logRecord)) {
7.       builder.append(logRecord.getLevel().getName())
8.               .append(": ");
9.     }
10.     builder.append(logRecord.getMessage());
11.     if (thrown != null) {
12.       builder.append(" [")
13.               .append(thrown.getMessage())
14.               .append("]");
15.     }
16.     builder.append(ENDL);
17. 
18.     if (thrown != null && atLeastWarningLevel(logRecord)) {
19.       StringWriter writer = new StringWriter();
20.       thrown.printStackTrace(new PrintWriter(writer));
21.       builder.append(writer.toString());
22.     }
23.     return builder.toString();

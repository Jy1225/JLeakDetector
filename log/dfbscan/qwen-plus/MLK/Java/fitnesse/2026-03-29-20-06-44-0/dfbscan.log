1. private ZipFileVersion loadZipEntry(final ZipFile zipFile, final File file) {
2.     final ZipEntry contentEntry = zipFile.getEntry(file.getName());
3.     if (contentEntry != null) {
4.       InputStream contentIS = null;
5.       try {
6.         contentIS = zipFile.getInputStream(contentEntry);
7.         return new ZipFileVersion(file, FileUtil.toString(contentIS), new Date(contentEntry.getTime()));
8.       } catch (Exception e) {
9.         throw new RuntimeException("Unable to load content for file " + file + " from " + zipFile, e);
10.       } finally {
11.         try {
12.           if (contentIS != null) {
13.             contentIS.close();
14.           }
15.         } catch (Exception e) {
16.           LOG.log(Level.WARNING, "Unable to read zip file contents", e);
17.         }
18.       }
19.     }
20.     return null;
21.   }

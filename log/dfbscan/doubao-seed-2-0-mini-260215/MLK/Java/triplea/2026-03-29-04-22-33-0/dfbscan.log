22.           promise.completeExceptionally(e);
23.           Thread.currentThread().interrupt();
24.         }
25.       }
26.     };
27.     final ProgressDialog progressDialog = new ProgressDialog(frame, message);
28.     worker.addPropertyChangeListener(new SwingWorkerCompletionWaiter(progressDialog));
29.     worker.execute();
30.     return promise;
31.   }

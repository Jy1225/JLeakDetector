1. private void startGameInNewThread(final byte[] gameData, final Map<String, INode> players,
2.       final boolean gameRunning) {
3.     final GameData data;
4.     try {
5.       // this normally takes a couple seconds, but can take
6.       // up to 60 seconds for a freaking huge game
7.       data = GameDataManager.loadGame(new ByteArrayInputStream(gameData), null);
8.     } catch (final IOException ex) {
9.       ClientLogger.logQuietly(ex);
10.       return;
11.     }
12.     m_objectStreamFactory.setData(data);
13.     final Map<String, String> playerMapping = new HashMap<>();
14.     for (final String player : m_playersToNodes.keySet()) {
15.       final String playedBy = m_playersToNodes.get(player);
16.       if (playedBy.equals(m_messenger.getLocalNode().getName())) {
17.         playerMapping.put(player, IGameLoader.CLIENT_PLAYER_TYPE);
18.       }
19.     }
20.     final Set<IGamePlayer> playerSet = data.getGameLoader().createPlayers(playerMapping);
21.     final Messengers messengers = new Messengers(m_messenger, m_remoteMessenger, m_channelMessenger);
22.     m_game = new ClientGame(data, playerSet, players, messengers);
23.     new Thread(() -> {
24.       SwingUtilities.invokeLater(() -> JOptionPane.getFrameForComponent(m_ui).setVisible(false));
25.       try {
26.         // game will be null if we loose the connection
27.         if (m_game != null) {
28.           try {
29.             data.getGameLoader().startGame(m_game, playerSet, false);
30.             data.testLocksOnRead();
31.           } catch (final Exception e) {
32.             ClientLogger.logError("Failed to start Game", e);
33.             m_game.shutDown();
34.             m_messenger.shutDown();
35.             m_gameLoadingWindow.doneWait();
36.             // an ugly hack, we need a better
37.             // way to get the main frame
38.             GameRunner.clientLeftGame();
39.           }
40.         }
41.         if (!gameRunning) {
42.           ((IServerReady) m_remoteMessenger.getRemote(CLIENT_READY_CHANNEL)).clientReady();
43.         }
44.       } finally {
45.         m_gameLoadingWindow.doneWait();
46.       }
47.     }, "Client Game Launcher").start();
48.   }
```

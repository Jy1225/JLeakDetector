1. public static void postTurn(final String title, final HistoryLog historyLog, final boolean includeSaveGame,
2.       final PBEMMessagePoster posterPbem, final IAbstractForumPosterDelegate postingDelegate,
3.       final MainGameFrame mainGameFrame, final JComponent postButton) {
4.     String message = "";
5.     final IForumPoster turnSummaryMsgr = posterPbem.getForumPoster();
6.     final StringBuilder sb = new StringBuilder();
7.     if (turnSummaryMsgr != null) {
8.       sb.append(message).append("Post ").append(title).append(" ");
9.       if (includeSaveGame) {
10.         sb.append("and save game ");
11.       }
12.       sb.append("to ").append(turnSummaryMsgr.getDisplayName()).append("?\n");
13.     }
14.     final IEmailSender emailSender = posterPbem.getEmailSender();
15.     if (emailSender != null) {
16.       sb.append("Send email to ").append(emailSender.getToAddress()).append("?\n");
17.     }
18.     message = sb.toString();
19.     final int choice = JOptionPane.showConfirmDialog(mainGameFrame, message, "Post " + title + "?", 2, -1, null);
20.     if (choice == 0) {
21.       if (postButton != null) {
22.         postButton.setEnabled(false);
23.       }
24.       final ProgressWindow progressWindow = new ProgressWindow(mainGameFrame, "Posting " + title + "...");
25.       progressWindow.setVisible(true);
26.       final Runnable t = () -> {
27.         boolean postOk = true;
28.         File saveGameFile = null;
29.         if (postingDelegate != null) {
30.           postingDelegate.setHasPostedTurnSummary(true);
31.         }
32.         try {
33.           saveGameFile = File.createTempFile("triplea", GameDataFileUtils.getExtension());
34.           if (saveGameFile != null) {
35.             mainGameFrame.getGame().saveGame(saveGameFile);
36.             posterPbem.setSaveGame(saveGameFile);
37.           }
38.         } catch (final Exception e) {
39.           postOk = false;
40.           ClientLogger.logQuietly(e);
41.         }
42.         posterPbem.setTurnSummary(historyLog.toString());
43.         try {
44.           // forward the poster to the delegate which invokes post() on the poster
45.           if (postingDelegate != null) {
46.             if (!postingDelegate.postTurnSummary(posterPbem, title, includeSaveGame)) {
47.               postOk = false;
48.             }
49.           } else {
50.             if (!posterPbem.post(null, title, includeSaveGame)) {
51.               postOk = false;
52.             }
53.           }
54.         } catch (final Exception e) {
55.           postOk = false;
56.           ClientLogger.logQuietly(e);
57.         }
58.         if (postingDelegate != null) {
59.           postingDelegate.setHasPostedTurnSummary(postOk);
60.         }
61.         final StringBuilder sb1 = new StringBuilder();
62.         if (posterPbem.getForumPoster() != null) {
63.           final String saveGameRef = posterPbem.getSaveGameRef();
64.           final String turnSummaryRef = posterPbem.getTurnSummaryRef();
65.           if (saveGameRef != null) {
66.             sb1.append("\nSave Game : ").append(saveGameRef);
67.           }
68.           if (turnSummaryRef != null) {
69.             sb1.append("\nSummary Text: ").append(turnSummaryRef);
70.           }
71.         }
72.         if (posterPbem.getEmailSender() != null) {
73.           sb1.append("\nEmails: ").append(posterPbem.getEmailSendStatus());
74.         }
75.         historyLog.getWriter().println(sb1.toString());
76.         if (historyLog.isVisible()) {
77.           historyLog.setVisible(true);

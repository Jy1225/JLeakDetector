69.             sb1.append("\nSummary Text: ").append(turnSummaryRef);
70.           }
71.         }
72.         if (posterPbem.getEmailSender() != null) {
73.           sb1.append("\nEmails: ").append(posterPbem.getEmailSendStatus());
74.         }
75.         historyLog.getWriter().println(sb1.toString());
76.         if (historyLog.isVisible()) {
77.           historyLog.setVisible(true);
78.         }
79.         try {
80.           if (saveGameFile != null && !saveGameFile.delete()) {
81.             System.out.println(
82.                 (new StringBuilder()).append("INFO TripleA PBEM/PBF poster couldn't delete temporary savegame: ")
83.                     .append(saveGameFile.getCanonicalPath()).toString());
84.           }
85.         } catch (final IOException e) {

36.       for (int i = 0; i < players.length; i++) {
37.         players[i] = clone.getPlayerList().getPlayerID(players[i].getName());
38.       }
39.       text.append(defaultFileName + ",");
40.       text.append("\n");
41.       text.append("TripleA Engine Version: ,");
42.       text.append(ClientContext.engineVersion() + ",");
43.       text.append("\n");
44.       text.append("Game Name: ,");
45.       text.append(gameData.getGameName() + ",");
46.       text.append("\n");
47.       text.append("Game Version: ,");
48.       text.append(gameData.getGameVersion() + ",");
49.       text.append("\n");
50.       text.append("\n");
51.       text.append("Current Round: ,");
52.       text.append(currentRound + ",");
53.       text.append("\n");
54.       text.append("Number of Players: ,");
55.       text.append(statPanel.getPlayers().size() + ",");
56.       text.append("\n");
57.       text.append("Number of Alliances: ,");
58.       text.append(statPanel.getAlliances().size() + ",");
59.       text.append("\n");
60.       text.append("\n");
61.       text.append("Turn Order: ,");
62.       text.append("\n");
63.       final List<PlayerID> playerOrderList = new ArrayList<>();
64.       playerOrderList.addAll(gameData.getPlayerList().getPlayers());
65.       Collections.sort(playerOrderList, new PlayerOrderComparator(gameData));
66.       final Set<PlayerID> playerOrderSetNoDuplicates = new LinkedHashSet<>(playerOrderList);
67.       final Iterator<PlayerID> playerOrderIterator = playerOrderSetNoDuplicates.iterator();
68.       while (playerOrderIterator.hasNext()) {
69.         final PlayerID currentPlayerId = playerOrderIterator.next();
70.         text.append(currentPlayerId.getName()).append(",");
71.         final Iterator<String> allianceName =
72.             gameData.getAllianceTracker().getAlliancesPlayerIsIn(currentPlayerId).iterator();
73.         while (allianceName.hasNext()) {
74.           text.append(allianceName.next()).append(",");
75.         }
76.         text.append("\n");
77.       }
78.       text.append("\n");
79.       text.append("Winners: ,");
80.       final EndRoundDelegate delegateEndRound = (EndRoundDelegate) gameData.getDelegateList().getDelegate("endRound");
81.       if (delegateEndRound != null && delegateEndRound.getWinners() != null) {
82.         for (final PlayerID p : delegateEndRound.getWinners()) {
83.           text.append(p.getName()).append(",");
84.         }
85.       } else {
86.         text.append("none yet; game not over,");
87.       }
88.       text.append("\n");
89.       text.append("\n");
90.       text.append("Resource Chart: ,");
91.       text.append("\n");
92.       final Iterator<Resource> resourceIterator = gameData.getResourceList().getResources().iterator();
93.       while (resourceIterator.hasNext()) {
94.         text.append(resourceIterator.next().getName() + ",");
95.         text.append("\n");
96.       }
97.       // if short, we won't both showing production and unit info
98.       if (showPhaseStats) {
99.         text.append("\n");
100.         text.append("Production Rules: ,");
101.         text.append("\n");
102.         text.append("Name,Result,Quantity,Cost,Resource,\n");
103.         final Iterator<ProductionRule> purchaseOptionsIterator =
104.             gameData.getProductionRuleList().getProductionRules().iterator();
105.         while (purchaseOptionsIterator.hasNext()) {
106.           final ProductionRule pr = purchaseOptionsIterator.next();
107.           String costString = pr.toStringCosts().replaceAll("; ", ",");
108.           costString = costString.replaceAll(" ", ",");
109.           text.append(pr.getName()).append(",").append(pr.getResults().keySet().iterator().next().getName()).append(",")
110.               .append(pr.getResults().getInt(pr.getResults().keySet().iterator().next())).append(",").append(costString)
111.               .append(",");
112.           text.append("\n");
113.         }
114.         text.append("\n");
115.         text.append("Unit Types: ,");
116.         text.append("\n");
117.         text.append("Name,Listed Abilities\n");
118.         final Iterator<UnitType> allUnitsIterator = gameData.getUnitTypeList().iterator();
119.         while (allUnitsIterator.hasNext()) {
120.           final UnitAttachment ua = UnitAttachment.get(allUnitsIterator.next());
121.           if (ua == null) {
122.             continue;
123.           }
124.           String toModify = ua.allUnitStatsForExporter();
125.           toModify = toModify.replaceFirst("UnitType called ", "").replaceFirst(" with:", "")
126.               .replaceAll("games.strategy.engine.data.", "").replaceAll("\n", ";").replaceAll(",", ";");
127.           toModify = toModify.replaceAll("  ", ",");
128.           toModify = toModify.replaceAll(", ", ",").replaceAll(" ,", ",");
129.           text.append(toModify);
130.           text.append("\n");
131.         }
132.       }
133.       text.append("\n");
134.       text.append((showPhaseStats ? "Full Stats (includes each phase that had activity),"
135.           : "Short Stats (only shows first phase with activity per player per round),"));
136.       text.append("\n");
137.       text.append("Turn Stats: ,");
138.       text.append("\n");
139.       text.append("Round,Player Turn,Phase Name,");
140.       for (final IStat stat : stats) {
141.         for (final PlayerID player : players) {
142.           text.append(stat.getName()).append(" ");
143.           text.append(player.getName());
144.           text.append(",");
145.         }
146.         for (final String alliance : alliances) {
147.           text.append(stat.getName()).append(" ");
148.           text.append(alliance);
149.           text.append(",");
150.         }
151.       }
152.       for (final IStat element : statsExtended) {
153.         for (final PlayerID player : players) {
154.           text.append(element.getName()).append(" ");
155.           text.append(player.getName());
156.           text.append(",");
157.         }
158.         for (final String alliance : alliances) {
159.           text.append(element.getName()).append(" ");
160.           text.append(alliance);
161.           text.append(",");
162.         }
163.       }
164.       text.append("\n");
165.       clone.getHistory().gotoNode(clone.getHistory().getLastNode());
166.       @SuppressWarnings("unchecked")
167.       final Enumeration<TreeNode> nodes = ((DefaultMutableTreeNode) clone.getHistory().getRoot()).preorderEnumeration();
168.       PlayerID currentPlayer = null;
169.       int round = 0;
170.       while (nodes.hasMoreElements()) {
171.         // we want to export on change of turn
172.         final HistoryNode element = (HistoryNode) nodes.nextElement();
173.         if (element instanceof Round) {
174.           round++;
175.         }
176.         if (!(element instanceof Step)) {
177.           continue;
178.         }
179.         final Step step = (Step) element;
180.         if (step.getPlayerID() == null || step.getPlayerID().isNull()) {
181.           continue;
182.         }
183.         // this is to stop from having multiple entries for each players turn.
184.         if (!showPhaseStats) {
185.           if (step.getPlayerID() == currentPlayer) {
186.             continue;
187.           }
188.         }
189.         currentPlayer = step.getPlayerID();
190.         clone.getHistory().gotoNode(element);
191.         final String playerName = step.getPlayerID() == null ? "" : step.getPlayerID().getName() + ": ";
192.         String stepName = step.getStepName();
193.         // copied directly from TripleAPlayer, will probably have to be updated in the future if more delegates are made
194.         if (stepName.endsWith("Bid")) {
195.           stepName = "Bid";
196.         } else if (stepName.endsWith("Tech")) {
197.           stepName = "Tech";
198.         } else if (stepName.endsWith("TechActivation")) {
199.           stepName = "TechActivation";
200.         } else if (stepName.endsWith("Purchase")) {
201.           stepName = "Purchase";
202.         } else if (stepName.endsWith("NonCombatMove")) {
203.           stepName = "NonCombatMove";
204.         } else if (stepName.endsWith("Move")) {
205.           stepName = "Move";
206.         } else if (stepName.endsWith("Battle")) {
207.           stepName = "Battle";
208.         } else if (stepName.endsWith("BidPlace")) {
209.           stepName = "BidPlace";
210.         } else if (stepName.endsWith("Place")) {
211.           stepName = "Place";
212.         } else if (stepName.endsWith("Politics")) {
213.           stepName = "Politics";
214.         } else if (stepName.endsWith("EndTurn")) {
215.           stepName = "EndTurn";
216.         } else {
217.           stepName = "";
218.         }
219.         text.append(round).append(",").append(playerName).append(",").append(stepName).append(",");
220.         for (final IStat stat : stats) {
221.           for (final PlayerID player : players) {
222.             text.append(stat.getFormatter().format(stat.getValue(player, clone)));
223.             text.append(",");
224.           }
225.           for (final String alliance : alliances) {
226.             text.append(stat.getFormatter().format(stat.getValue(alliance, clone)));
227.             text.append(",");
228.           }
229.         }
230.         for (final IStat element2 : statsExtended) {
231.           for (final PlayerID player : players) {
232.             text.append(element2.getFormatter().format(element2.getValue(player, clone)));
233.             text.append(",");
234.           }
235.           for (final String alliance : alliances) {
236.             text.append(element2.getFormatter().format(element2.getValue(alliance, clone)));
237.             text.append(",");
238.           }
239.         }
240.         text.append("\n");
241.       }
242.     } finally {
243.       gameData.releaseReadLock();
244.     }
245.     try (final FileWriter writer = new FileWriter(chooser.getSelectedFile())) {
246.       writer.write(text.toString());
247.     } catch (final IOException e1) {
248.       ClientLogger.logQuietly(e1);
249.     }
250.   }

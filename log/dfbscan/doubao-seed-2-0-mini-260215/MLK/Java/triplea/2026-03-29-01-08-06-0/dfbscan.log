7.       final EditDelegate delegate = new EditDelegate();
8.       delegate.initialize("edit", "edit");
9.       game.getData().getDelegateList().addDelegate(delegate);
10.       if (game instanceof ServerGame) {
11.         ((ServerGame) game).addDelegateMessenger(delegate);
12.       }
13.     }
14.     final LocalPlayers localPlayers = new LocalPlayers(players);

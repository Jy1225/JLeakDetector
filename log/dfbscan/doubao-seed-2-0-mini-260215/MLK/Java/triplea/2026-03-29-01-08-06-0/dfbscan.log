22.     // todo get the turn and player number from the game data
23.     try {
24.       final Session session = Session.getInstance(props, null);
25.       final MimeMessage mimeMessage = new MimeMessage(session);
26.       // Build the message fields one by one:
27.       // priority
28.       mimeMessage.setHeader("X-Priority", "3 (Normal)");
29.       // from
30.       mimeMessage.setFrom(new InternetAddress(from));
31.       // to address
32.       final StringTokenizer toAddresses = new StringTokenizer(to, " ", false);
33.       while (toAddresses.hasMoreTokens()) {
34.         mimeMessage.addRecipient(Message.RecipientType.TO, new InternetAddress(toAddresses.nextToken().trim()));
35.       }
36.       // subject
37.       mimeMessage.setSubject(m_subjectPrefix + " " + subject);
38.       final MimeBodyPart bodypart = new MimeBodyPart();
39.       bodypart.setText(htmlMessage, "UTF-8");
40.       bodypart.setHeader("Content-Type", "text/html");
41.       if (saveGame != null) {
42.         final Multipart multipart = new MimeMultipart();
43.         multipart.addBodyPart(bodypart);
44.         // add save game
45.         final FileInputStream fin = new FileInputStream(saveGame);
46.         final DataSource source = new ByteArrayDataSource(fin, "application/triplea");
47.         final BodyPart messageBodyPart = new MimeBodyPart();
48.         messageBodyPart.setDataHandler(new DataHandler(source));
49.         messageBodyPart.setFileName(saveGameName);
50.         multipart.addBodyPart(messageBodyPart);
51.         mimeMessage.setContent(multipart);
52.       }
53.       // date
54.       try {
55.         mimeMessage.setSentDate(Date.from(Instant.now()));
56.       } catch (final Exception e) {
57.         // NoOp - the Date field is simply ignored in this case
58.       }
59.       final Transport transport = session.getTransport("smtp");
60.       if (getUserName() != null) {
61.         transport.connect(getHost(), getPort(), getUserName(), getPassword());
62.       } else {
63.         transport.connect();
64.       }
65.       mimeMessage.saveChanges();
66.       transport.sendMessage(mimeMessage, mimeMessage.getAllRecipients());
67.       transport.close();
68.     } catch (final MessagingException e) {
69.       throw new IOException(e.getMessage());
70.     }
71.   }

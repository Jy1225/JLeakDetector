36.               String stepDisplayName = datacopy.getSequence().getStep(0).getDisplayName();
37.               PlayerID currentPlayer = datacopy.getSequence().getStep(0).getPlayerID();
38.               while (enumeration.hasMoreElements()) {
39.                 final HistoryNode node = (HistoryNode) enumeration.nextElement();
40.                 if (node instanceof Round) {
41.                   round = Math.max(0, ((Round) node).getRoundNo() - datacopy.getSequence().getRoundOffset());
42.                   currentPlayer = null;
43.                   stepDisplayName = node.getTitle();
44.                 } else if (node instanceof Step) {
45.                   currentPlayer = ((Step) node).getPlayerID();
46.                   stepDisplayName = node.getTitle();
47.                 }
48.               }
49.               datacopy.getSequence().setRoundAndStep(round, stepDisplayName, currentPlayer);
50.               GameDataManager.saveGame(fout, datacopy);
51.               JOptionPane.showMessageDialog(TripleAFrame.this, "Game Saved", "Game Saved",
52.                   JOptionPane.INFORMATION_MESSAGE);
53.             } catch (final IOException e) {
54.               ClientLogger.logQuietly(e);
55.             }
56.           }
57.         } finally {
58.           data.releaseReadLock();
59.         }
60.         historyPanel.clearCurrentPopupNode();
61.       }

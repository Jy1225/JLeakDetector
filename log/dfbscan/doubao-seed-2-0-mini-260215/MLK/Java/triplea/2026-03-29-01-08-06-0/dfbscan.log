18.       uiContext.setLocalPlayers(localPlayers);
19.       display = new HeadlessDisplay();
20.       soundChannel = new HeadlessSoundChannel();
21.       game.addDisplay(display);
22.       game.addSoundChannel(soundChannel);
23. 
24.       // technically not needed because we won't have any "local human players" in a headless game.
25.       connectPlayers(players, null);
26.     } else {
27.       try {
28.         SwingUtilities.invokeAndWait(() -> {
29.           final TripleAFrame frame;

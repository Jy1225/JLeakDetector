1. private static byte[] getBytesFromFile(final File file) {
2.     if (file == null || !file.exists()) {
3.       return null;
4.     }
5.     // Get the size of the file
6.     final long length = file.length();
7.     if (length > Integer.MAX_VALUE) {
8.       return null;
9.     }
10.     // Create the byte array to hold the data
11.     final byte[] bytes = new byte[(int) length];
12.     try (InputStream is = new FileInputStream(file)) {
13.       is.read(bytes);
14.     } catch (final IOException e) {
15.       ClientLogger.logQuietly("Failed to read file: " + file);
16.       ClientLogger.logQuietly(e);
17.     }
18.     return bytes;
19.   }

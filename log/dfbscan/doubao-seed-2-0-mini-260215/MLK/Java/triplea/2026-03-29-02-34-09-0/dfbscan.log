130.                   round = Math.max(0, ((Round) node).getRoundNo() - datacopy.getSequence().getRoundOffset());
131.                   currentPlayer = null;
132.                   stepDisplayName = node.getTitle();
133.                 } else if (node instanceof Step) {
134.                   currentPlayer = ((Step) node).getPlayerID();
135.                   stepDisplayName = node.getTitle();
136.                 }
137.               }
138.               datacopy.getSequence().setRoundAndStep(round, stepDisplayName, currentPlayer);
139.               GameDataManager.saveGame(fout, datacopy);
140.               JOptionPane.showMessageDialog(TripleAFrame.this, "Game Saved", "Game Saved",
141.                   JOptionPane.INFORMATION_MESSAGE);
142.             } catch (final IOException e) {
143.               ClientLogger.logQuietly(e);
144.             }
145.           }
146.         } finally {
147.           data.releaseReadLock();
148.         }
149.         historyPanel.clearCurrentPopupNode();
150.       }
151.     });
152.     final JSplitPane split = new JSplitPane();
153.     split.setOneTouchExpandable(true);
154.     split.setDividerSize(8);
155.     historyPanel = new HistoryPanel(clonedGameData, historyDetailPanel, popup, uiContext);
156.     split.setLeftComponent(historyPanel);
157.     split.setRightComponent(gameCenterPanel);
158.     split.setDividerLocation(150);
159.     historyComponent.add(split, BorderLayout.CENTER);
160.     historyComponent.add(gameSouthPanel, BorderLayout.SOUTH);
161.     getContentPane().removeAll();
162.     getContentPane().add(historyComponent, BorderLayout.CENTER);
163.     validate();
164.   }

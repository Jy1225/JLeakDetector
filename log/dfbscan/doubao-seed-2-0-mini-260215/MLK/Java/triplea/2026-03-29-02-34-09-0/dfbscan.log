8.       // shut the database down on finish
9.       Runtime.getRuntime().addShutdownHook(new Thread(() -> shutDownDB()));
10.       isDbSetup = true;
11.     }
12.     // we want to backup the database on occassion
13.     final Thread backupThread = new Thread(() -> {
14.       while (true) {
15.         // wait 7 days
16.         if (!ThreadUtil.sleep(7 * 24 * 60 * 60 * 1000)) {
17.           break;
18.         }
19.         backup();
20.       }
21.     }, "TripleA Database Backup Thread");
22.     backupThread.setDaemon(true);
23.     backupThread.start();
24.   }
```

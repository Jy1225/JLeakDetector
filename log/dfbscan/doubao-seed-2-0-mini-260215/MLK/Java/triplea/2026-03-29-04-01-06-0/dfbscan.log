13.       thisSoundUri = thisSoundUrl.toURI();
14.       try {
15.         thisSoundFile = new File(thisSoundUri);
16.       } catch (final Exception e) {
17.         try {
18.           thisSoundFile = new File(thisSoundUri.getPath());
19.         } catch (final Exception e3) {
20.           thisSoundFile = new File(thisSoundUrl.getPath());
21.         }
22.       }
23.     } catch (final URISyntaxException e1) {
24.       try {
25.         thisSoundFile = new File(thisSoundUrl.getPath());
26.       } catch (final Exception e4) {
27.         thisSoundFile = null;
28.       }
29.     } catch (final Exception e2) {
30.       thisSoundFile = null;
31.     }
32. 
33.     if (thisSoundFile == null || !thisSoundFile.exists()) {
34.       // final long startTime = System.currentTimeMillis();
35.       // we are probably using zipped sounds. there might be a better way to do this...
36.       final String soundFilePath = thisSoundUrl.getPath();
37.       if (soundFilePath != null && soundFilePath.length() > 5 && soundFilePath.contains(".zip!")) {
38.         // so the URL with a zip or jar in it, will start with "file:", and unfortunately when you make a file and test
39.         // if it exists, if it
40.         // starts with that it doesn't exist
41.         final int index1 = Math.max(0, Math.min(soundFilePath.length(),
42.             soundFilePath.contains("file:") ? soundFilePath.indexOf("file:") + 5 : 0));
43.         final String zipFilePath = soundFilePath.substring(index1,
44.             Math.max(index1, Math.min(soundFilePath.length(), soundFilePath.lastIndexOf("!"))));
45.         if (zipFilePath.length() > 5 && zipFilePath.endsWith(".zip")) {
46.           String decoded;
47.           try {
48.             // the file path may have spaces, which in a URL are equal to %20, but if we make a file using that it will
49.             // fail, so we need to decode
50.             decoded = URLDecoder.decode(zipFilePath, "UTF-8");
51.           } catch (final UnsupportedEncodingException uee) {
52.             decoded = zipFilePath.replaceAll("%20", " ");
53.           }
54. 

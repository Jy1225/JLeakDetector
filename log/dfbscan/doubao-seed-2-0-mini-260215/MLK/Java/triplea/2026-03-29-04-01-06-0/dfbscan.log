1. @Override
2.   public int[] getRandom(final int max, final int count, final String annotation)
3.       throws IllegalArgumentException, IllegalStateException {
4.     if (count <= 0) {
5.       throw new IllegalArgumentException("Invalid count:" + count);
6.     }
7.     final Vault vault = m_game.getVault();
8.     // generate numbers locally, and put them in the vault
9.     final int[] localRandom = m_plainRandom.getRandom(max, count, annotation);
10.     // lock it so the client knows that its there, but cant read it
11.     final VaultID localId = vault.lock(intsToBytes(localRandom));
12.     // ask the remote to generate numbers
13.     final IRemoteRandom remote =
14.         (IRemoteRandom) (m_game.getRemoteMessenger().getRemote(ServerGame.getRemoteRandomName(m_remotePlayer)));
15.     final Object clientRandom = remote.generate(max, count, annotation, localId);
16.     if (!(clientRandom instanceof int[])) {
17.       // Let the error be thrown
18.       System.out.println("Client remote random generated: " + clientRandom + ".  Asked for: " + count + "x" + max
19.           + " for " + annotation);
20.     }
21.     final int[] remoteNumbers = (int[]) clientRandom;
22.     // unlock ours, tell the client he can verify
23.     vault.unlock(localId);
24.     remote.verifyNumbers();
25.     // finally, we join the two together to get the real value
26.     return xor(localRandom, remoteNumbers, max);
27.   }

42.       }
43.     } catch (final Exception e) {
44.       ClientLogger.logQuietly("Error while trying to get mac address", e);
45.     }
46.     // Next, try to get the mac address by calling the 'ipconfig -all' app that exists in Windows and possibly others.
47.     /*
48.      * ...
49.      * Physical Address. . . . . . . . . : 00-1C-D3-F8-DC-E8
50.      * ...
51.      */
52.     try {

10.       try (InputStream input = inputStream.get()) {
11.         final GameData data = new GameParser(uri.toString()).parse(input, gameName, delayedParsing);
12.         final String name = data.getGameName();
13.         final String mapName = data.getProperties().get(Constants.MAP_NAME, "");
14.         if (!availableGames.containsKey(name)) {
15.           availableGames.put(name, uri);
16.           if (mapName.length() > 0) {
17.             mapNamePropertyList.add(mapName);
18.           }
19.           return true;
20.         }
21.       } catch (final Exception e) {
22.         ClientLogger.logError("Exception while parsing: " + uri.toString() + " : "
23.             + (gameName.get() != null ? gameName.get() + " : " : ""), e);
24.       }
25.     }
26.     return false;
27.   }

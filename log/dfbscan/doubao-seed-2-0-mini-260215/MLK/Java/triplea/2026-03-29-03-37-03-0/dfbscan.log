1. private static String getMacAddress() {
2.     // We must try different methods of obtaining the mac address because not all the methods work on each system, and
3.     // if we can't obtain
4.     // the mac, we can't login to the lobby
5.     // First, try to get the mac address of the local host network interface
6.     try {
7.       final InetAddress address = InetAddress.getLocalHost();
8.       final NetworkInterface localHostNetworkInterface = NetworkInterface.getByInetAddress(address);
9.       if (localHostNetworkInterface != null) {
10.         final byte[] rawMac = localHostNetworkInterface.getHardwareAddress();
11.         final String mac = convertMacBytesToString(rawMac);
12.         if (isMacValid(mac)) {
13.           return mac;
14.         }
15.       }
16.     } catch (final SocketException | UnknownHostException e) {
17.       ClientLogger.logError("Error while trying to get a valid MAC adress", e);
18.     }
19.     // Next, try to get the mac address of the first network interfaces that has an accessible mac address
20.     try {
21.       for (final NetworkInterface ni : Collections.list(NetworkInterface.getNetworkInterfaces())) {
22.         final byte[] rawMac = ni.getHardwareAddress();
23.         final String mac = convertMacBytesToString(rawMac);
24.         if (isMacValid(mac)) {
25.           return mac;
26.         }
27.       }
28.     } catch (final SocketException e) {
29.       ClientLogger.logError("Error while trying to get a valid MAC adress", e);
30.     }

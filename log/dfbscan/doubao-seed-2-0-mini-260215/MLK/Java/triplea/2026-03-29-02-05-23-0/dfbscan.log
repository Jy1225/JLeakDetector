1. private void rollInSeperateThread() throws IllegalStateException {
2.       if (SwingUtilities.isEventDispatchThread()) {
3.         throw new IllegalStateException("Wrong thread");
4.       }
5.       while (!isVisible()) {
6.         Thread.yield();
7.       }
8.       appendText(m_subjectMessage + "\n");
9.       appendText("Contacting  " + m_diceServer.getDisplayName() + "\n");
10.       String text = null;
11.       try {
12.         text = m_diceServer.postRequest(m_sides, m_count, m_subjectMessage, m_gameID, m_gameUUID);
13.         if (text.length() == 0) {
14.           appendText("Nothing could be read from dice server\n");
15.           appendText("Please check your firewall settings");
16.           notifyError();
17.         }
18.         if (!m_test) {
19.           appendText("Contacted :" + text + "\n");
20.         }
21.         m_diceRoll = m_diceServer.getDice(text, m_count);
22.         appendText("Success!");
23.         if (!m_test) {
24.           closeAndReturn();
25.         }
26.       } catch (final SocketException ex) { // an error in networking
27.         appendText("Connection failure:" + ex.getMessage() + "\n"
28.             + "Please ensure your Internet connection is working, and try again.");
29.         notifyError();
30.       } catch (final InvocationTargetException e) {
31.         appendText("\nError:" + e.getMessage() + "\n\n");
32.         appendText("Text from dice server:\n" + text + "\n");
33.         notifyError();
34.       } catch (final IOException ex) {
35.         try {
36.           appendText("An error has occured!\n");
37.           appendText("Possible reasons the error could have happened:\n");
38.           appendText("  1: An invalid e-mail address\n");
39.           appendText("  2: Firewall could be blocking TripleA from connecting to the Dice Server\n");
40.           appendText("  3: The e-mail address does not exist\n");
41.           appendText("  4: An unknown error, please see the error console and consult the forums for help\n");
42.           appendText("     Visit https://forums.triplea-game.org  for extra help\n");
43.           if (text != null) {
44.             appendText("Text from dice server:\n" + text + "\n");
45.           }
46.           final StringWriter writer = new StringWriter();
47.           ex.printStackTrace(new PrintWriter(writer));
48.           writer.close();
49.           appendText(writer.toString());
50.         } catch (final IOException ex1) {
51.           ex1.printStackTrace();
52.         }
53.         notifyError();
54.       }
55.     }

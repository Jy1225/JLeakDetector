1. private static String getMacAddress() {
2.     // We must try different methods of obtaining the mac address because not all the methods work on each system, and
3.     // if we can't obtain
4.     // the mac, we can't login to the lobby
5.     // First, try to get the mac address of the local host network interface
6.     try {
7.       final InetAddress address = InetAddress.getLocalHost();
8.       final NetworkInterface localHostNetworkInterface = NetworkInterface.getByInetAddress(address);
9.       if (localHostNetworkInterface != null) {
10.         final byte[] rawMac = localHostNetworkInterface.getHardwareAddress();
11.         final String mac = convertMacBytesToString(rawMac);
12.         if (isMacValid(mac)) {
13.           return mac;
14.         }
15.       }
16.     } catch (final SocketException | UnknownHostException e) {
17.       ClientLogger.logError("Error while trying to get a valid MAC adress", e);
18.     }
19.     // Next, try to get the mac address of the first network interfaces that has an accessible mac address
20.     try {
21.       for (final NetworkInterface ni : Collections.list(NetworkInterface.getNetworkInterfaces())) {
22.         final byte[] rawMac = ni.getHardwareAddress();
23.         final String mac = convertMacBytesToString(rawMac);
24.         if (isMacValid(mac)) {
25.           return mac;
26.         }
27.       }
28.     } catch (final SocketException e) {
29.       ClientLogger.logError("Error while trying to get a valid MAC adress", e);
30.     }
31.     // Next, try to get the mac address by calling the 'getmac' app that exists in Windows, Mac, and possibly others.
32.     /*
33.      * Physical Address Transport Name
34.      * =================== ==========================================================
35.      * 00-1F-C6-F9-EC-E8 \Device\Tcpip_{99F55DF7-8C43-464C-A8A9-FA3F847467CB}
36.      */
37.     try {
38.       final String results = executeCommandAndGetResults("getmac");
39.       final String mac = tryToParseMACFromOutput(results, Arrays.asList("-", ":", "."), false);
40.       if (isMacValid(mac)) {
41.         return mac;
42.       }
43.     } catch (final Exception e) {
44.       ClientLogger.logQuietly("Error while trying to get mac address", e);
45.     }
46.     // Next, try to get the mac address by calling the 'ipconfig -all' app that exists in Windows and possibly others.
47.     /*
48.      * ...
49.      * Physical Address. . . . . . . . . : 00-1C-D3-F8-DC-E8
50.      * ...
51.      */
52.     try {
53.       final String results = executeCommandAndGetResults("ipconfig -all");
54.       final String mac = tryToParseMACFromOutput(results, Arrays.asList("-", ":", "."), false);
55.       if (isMacValid(mac)) {
56.         return mac;
57.       }
58.     } catch (final Exception e) {
59.       ClientLogger.logQuietly("Error while trying to get mac address", e);
60.     }
61.     try {
62.       // ipconfig -all does not work on my computer, while ipconfig /all does not work on others computers
63.       final String results = executeCommandAndGetResults("ipconfig /all");
64.       final String mac = tryToParseMACFromOutput(results, Arrays.asList("-", ":", "."), false);
65.       if (isMacValid(mac)) {
66.         return mac;
67.       }
68.     } catch (final Exception e) {
69.       ClientLogger.logQuietly("Error while trying to get mac address", e);
70.     }
71.     // Next, try to get the mac address by calling the 'ifconfig -a' app that exists in Linux and possibly others. May
72.     // have 1 or 2 spaces
73.     // between Ethernet and HWaddr, and may be wireless instead of ethernet.
74.     /*
75.      * ...
76.      * eth0 Link encap:Ethernet HWaddr 00:08:C7:1B:8C:02
77.      * ...
78.      */
79.     try {

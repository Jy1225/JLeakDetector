```
1. public void addBannedUsername(final String username, final Instant banTill) {
2.     if (isUsernameBanned(username).getFirst()) {
3.       removeBannedUsername(username);
4.     }
5.     Timestamp banTillTs = null;
6.     if (banTill != null) {
7.       banTillTs = new Timestamp(banTill.toEpochMilli());
8.     }
9.     logger.fine("Banning username:" + username);
10.     final Connection con = Database.getDerbyConnection();
11.     try {
12.       final PreparedStatement ps =
13.           con.prepareStatement("insert into banned_usernames (username, ban_till) values (?, ?)");
14.       ps.setString(1, username);
15.       ps.setTimestamp(2, banTillTs);
16.       ps.execute();
17.       ps.close();
18.       con.commit();
19.     } catch (final SQLException sqle) {
20.       if (sqle.getErrorCode() == 30000) {
21.         // this is ok
22.         // the username is banned as expected
23.         logger.info("Tried to create duplicate banned username:" + username + " error:" + sqle.getMessage());
24.         return;
25.       }
26.       throw new IllegalStateException("Error inserting banned username:" + username, sqle);
27.     } finally {
28.       DbUtil.closeConnection(con);
29.     }
30.   }
```

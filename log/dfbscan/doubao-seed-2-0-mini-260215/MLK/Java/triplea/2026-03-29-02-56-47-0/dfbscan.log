1. private static void populateFromZip(final File map, final Map<String, URI> availableGames,
2.       final Set<String> availableMapFolderOrZipNames, final Set<String> mapNamePropertyList) {
3.     try (
4.         final FileInputStream fis = new FileInputStream(map);
5.         final ZipInputStream zis = new ZipInputStream(fis);
6.         final URLClassLoader loader = new URLClassLoader(new URL[] {map.toURI().toURL()})) {
7.       ZipEntry entry = zis.getNextEntry();
8.       while (entry != null) {
9.         if (entry.getName().contains("games/") && entry.getName().toLowerCase().endsWith(".xml")) {
10.           final URL url = loader.getResource(entry.getName());
11.           if (url != null) {
12.             try {
13.               final boolean added = addToAvailableGames(
14.                   new URI(url.toString().replace(" ", "%20")),
15.                   availableGames,
16.                   mapNamePropertyList);
17.               if (added && map.getName().length() > 4) {
18.                 availableMapFolderOrZipNames
19.                     .add(map.getName().substring(0, map.getName().length() - ZIP_EXTENSION.length()));
20.               }
21.             } catch (final URISyntaxException e) {
22.               // only happens when URI couldn't be build and therefore no entry was added. That's fine
23.             }
24.           }
25.         }
26.         // we have to close the loader to allow files to be deleted on windows
27.         zis.closeEntry();
28.         entry = zis.getNextEntry();
29.       }
30.     } catch (final IOException e) {
31.       ClientLogger.logQuietly("Map: " + map, e);
32.     }
33.   }

13.       throw new IOException("The remote resource, " + remoteUrl() + ", was not found.");
14.     if (parser.getStatus() == 401)
15.       throw new AuthenticationRequiredException(remoteUrl());
16. 
17.     String body = parser.getBody();
18.     return XmlUtil.newDocument(body);
19.   }

10.             return new WikiWordBuilder(translator.getPage(), linkReference.childAt(0).getContent(), linkBody)
11.                     .buildLink(translator.translate(linkReference.childrenAfter(0)), linkBody);
12.         }
13. 
14.         HtmlTag alias = new HtmlTag("a", linkBody);
15. 
16.         if (linkReference.childAt(0).isType(Link.symbolType)) {
17.             alias.addAttribute("href", linkReferenceString.startsWith("http://files/") ? linkReferenceString.substring(7) : linkReferenceString);
18.         } else {
19.             alias.addAttribute("href", translator.translate(linkReference));
20.         }
21. 
